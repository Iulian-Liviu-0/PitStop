@if (Variant == ShopCardVariant.Grid)
{
    <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 flex flex-col border border-border-light group">
        <div class="h-48 relative overflow-hidden bg-gray-100">
            <img src="@Shop.ImageUrl" alt="@Shop.Name"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-brand-red px-3 py-1 rounded-full font-bold text-xs flex items-center gap-1 shadow-sm border border-brand-red-mid" style="font-family: Manrope, sans-serif;">
                @if (Shop.Icon is not null)
                {
                    <span class="material-symbols-outlined text-sm">@Shop.Icon</span>
                }
                @Shop.Category
            </div>
        </div>
        <div class="p-5 flex-1 flex flex-col">
            <div class="flex justify-between items-start mb-1">
                <h3 class="font-bold text-lg text-text-main" style="font-family: Manrope, sans-serif;">@Shop.Name</h3>
                <div class="flex items-center gap-1 bg-brand-red-light text-brand-red px-2 py-1 rounded-full">
                    <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                    <span class="font-bold text-xs" style="font-family: Manrope, sans-serif;">@Shop.Rating</span>
                </div>
            </div>
            <div class="flex items-center text-text-muted text-sm mb-3 gap-1">
                <span class="material-symbols-outlined text-sm">location_on</span>
                @Shop.Location
            </div>
            <p class="text-text-muted text-sm mb-5 flex-1">@Shop.Description</p>
            <a href="/serviciu/@Shop.Id"
               class="inline-flex items-center justify-center border border-brand-red text-brand-red hover:bg-brand-red hover:text-white font-bold py-2.5 px-4 rounded-lg transition-all text-sm w-full gap-2" style="font-family: Manrope, sans-serif;">
                Vezi detalii
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
        </div>
    </div>
}
else
{
    <article class="bg-white rounded-xl overflow-hidden group hover:-translate-y-1 transition-transform duration-300 border border-gray-100 shadow-sm flex flex-col sm:flex-row">
        <div class="relative w-full sm:w-2/5 h-48 sm:h-auto overflow-hidden bg-gray-100">
            <img src="@Shop.ImageUrl" alt="@Shop.Name"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute top-3 left-3">
                <span class="bg-brand-red/90 backdrop-blur-sm text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full shadow-sm">
                    @Shop.Category
                </span>
            </div>
        </div>
        <div class="p-5 flex flex-col justify-between w-full sm:w-3/5">
            <div>
                <div class="flex justify-between items-start mb-1">
                    <h2 class="font-bold text-lg text-text-main leading-tight" style="font-family: Manrope, sans-serif;">@Shop.Name</h2>
                    <button class="text-gray-400 hover:text-brand-red transition-colors">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">favorite</span>
                    </button>
                </div>
                <div class="flex items-center text-sm text-text-warm mb-3 gap-1">
                    <span class="material-symbols-outlined text-base">location_on</span>
                    <span>@Shop.Location</span>
                </div>
                <div class="flex items-center gap-2 mb-3">
                    <div class="flex items-center text-brand-red">
                        <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="font-semibold ml-1">@Shop.Rating</span>
                    </div>
                    @if (Shop.ReviewCount is not null)
                    {
                        <span class="text-sm text-text-warm">(@Shop.ReviewCount recenzii)</span>
                        <span class="w-1 h-1 rounded-full bg-gray-300 mx-1"></span>
                    }
                    @if (Shop.IsOpen == true)
                    {
                        <span class="text-xs font-semibold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">Deschis acum</span>
                    }
                    else if (Shop.IsOpen == false)
                    {
                        <span class="text-xs font-semibold text-rose-600 bg-rose-50 px-2 py-0.5 rounded-full">Închis</span>
                    }
                </div>
                <p class="text-sm text-text-warm line-clamp-2 mb-4">@Shop.Description</p>
            </div>
            <a href="/serviciu/@Shop.Id"
               class="w-full py-2.5 px-4 text-sm font-semibold text-brand-red border border-brand-red/30 rounded hover:bg-brand-red hover:text-white transition-colors text-center">
                Vezi detalii
            </a>
        </div>
    </article>
}

@code {
    [Parameter, EditorRequired] public ShopCardModel Shop { get; set; } = default!;
    [Parameter] public ShopCardVariant Variant { get; set; } = ShopCardVariant.Grid;
}
