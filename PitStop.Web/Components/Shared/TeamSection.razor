<section class="bg-surface-container py-24 px-6 md:px-12">
    <div class="max-w-screen-xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="font-bold text-3xl md:text-4xl text-text-main" style="font-family: Manrope, sans-serif;">Echipa
                din spatele PitStop</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

            @foreach (var member in Members)
            {
                <div class="bg-white rounded-xl p-8 flex flex-col items-center text-center border border-border-light">
                    <img src="@member.PhotoUrl"
                         alt="@member.Name"
                         class="w-24 h-24 rounded-full object-cover mb-5 grayscale border-4 border-surface-container"/>
                    <h3 class="font-bold text-lg text-text-main"
                        style="font-family: Manrope, sans-serif;">@member.Name</h3>
                    <p class="text-brand-red text-sm font-medium mt-1">@member.Role</p>
                </div>
            }

        </div>
    </div>
</section>

