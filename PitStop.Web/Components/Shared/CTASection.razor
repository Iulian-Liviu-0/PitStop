@if (Variant == CTAVariant.DarkHorizontal)
{
    <section class="py-16 px-6 md:px-10 bg-brand-navy">
        <div class="max-w-screen-xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
            <div>
                <h2 class="font-extrabold text-2xl md:text-3xl text-white mb-2" style="font-family: Manrope, sans-serif;">@Title</h2>
                <p class="text-white/60 text-sm">@Subtitle</p>
            </div>
            <a href="@ButtonHref"
               class="shrink-0 bg-brand-red hover:bg-brand-red-dark text-white font-bold px-8 py-3 rounded-lg transition-colors shadow-lg text-sm whitespace-nowrap"
               style="font-family: Manrope, sans-serif;">
                @ButtonText
            </a>
        </div>
    </section>
}
else
{
    <section class="bg-brand-red py-20 px-6 md:px-12">
        <div class="max-w-4xl mx-auto text-center flex flex-col items-center gap-6">
            <h2 class="font-black text-3xl md:text-5xl text-white tracking-tight" style="font-family: Manrope, sans-serif;">@Title</h2>
            <p class="text-lg text-white/90 max-w-2xl">@Subtitle</p>
            <a href="@ButtonHref"
               class="mt-2 px-8 py-3.5 border-2 border-white text-white font-bold rounded-lg hover:bg-white hover:text-brand-red transition-colors duration-200"
               style="font-family: Manrope, sans-serif;">
                @ButtonText
            </a>
        </div>
    </section>
}

@code {
    public enum CTAVariant { DarkHorizontal, RedCentered }

    [Parameter] public CTAVariant Variant { get; set; } = CTAVariant.DarkHorizontal;
    [Parameter, EditorRequired] public string Title { get; set; } = default!;
    [Parameter, EditorRequired] public string Subtitle { get; set; } = default!;
    [Parameter] public string ButtonText { get; set; } = "Listează-ți afacerea →";
    [Parameter] public string ButtonHref { get; set; } = "/contact";
}
