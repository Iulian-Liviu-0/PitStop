@if (Services.Count > 0)
{
    <div class="bg-white rounded-xl p-8 shadow-sm border border-border-light">
        <h2 class="font-bold text-2xl text-text-main mb-6" style="font-family: Manrope, sans-serif;">Servicii
            oferite</h2>
        <div class="space-y-3">
            @foreach (var service in Services)
            {
                <div
                    class="flex items-center justify-between p-4 bg-surface-low rounded-lg hover:bg-surface-container transition-colors border border-border-light">
                    <div class="flex-1 mr-4">
                        <h4 class="font-bold text-text-main">@service.Name</h4>
                        <p class="text-sm text-text-muted">@service.Description</p>
                    </div>
                    <span class="bg-brand-red text-white px-3 py-1 rounded font-bold text-sm whitespace-nowrap">
                        @service.PriceRange
                    </span>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public List<ServiceItem> Services { get; set; } = [];
}
