<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal" data-nosnippet>
    <div class="reconnect-inner">

        <div class="reconnect-brand">
            <span class="reconnect-brand-dot"></span>PitStop
        </div>

        <div class="reconnect-spinner" aria-hidden="true"></div>

        <p class="components-reconnect-first-attempt-visible reconnect-label">
            Se reconectează la server...
        </p>
        <p class="components-reconnect-repeated-attempt-visible reconnect-label">
            Reîncercare în <span id="components-seconds-to-next-attempt"></span> secunde...
        </p>
        <p class="components-reconnect-failed-visible reconnect-label reconnect-label--muted">
            Conexiunea a fost pierdută.<br/>Reîncercați sau reîncărcați pagina.
        </p>
        <p class="components-pause-visible reconnect-label reconnect-label--muted">
            Sesiunea a fost întreruptă de server.
        </p>
        <p class="components-resume-failed-visible reconnect-label reconnect-label--muted">
            Reluarea sesiunii a eșuat.<br/>Reîncercați sau reîncărcați pagina.
        </p>

        <button id="components-reconnect-button" class="components-reconnect-failed-visible reconnect-btn">
            Reîncearcă
        </button>
        <button id="components-resume-button"
                class="components-pause-visible components-resume-failed-visible reconnect-btn">
            Reia sesiunea
        </button>

    </div>
</dialog>
