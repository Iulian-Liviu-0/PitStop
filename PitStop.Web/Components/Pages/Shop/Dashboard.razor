@page "/shop/dashboard"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IShopRepository ShopRepo
@inject IReviewRepository ReviewRepo
@inject IFileStorage FileStorage

<PageTitle>Dashboard Service - PitStop</PageTitle>

@if (_loading)
{
    <div class="flex items-center justify-center min-h-screen text-text-muted gap-2">
        <span class="material-symbols-outlined animate-spin">progress_activity</span>
        Se încarcă...
    </div>
}
else if (_shop is null)
{
    <div class="min-h-screen bg-surface flex flex-col items-center justify-center gap-4 text-center px-6">
        <span class="material-symbols-outlined text-6xl text-text-muted">store_off</span>
        <h1 class="font-bold text-2xl text-text-main" style="font-family: Manrope, sans-serif;">Niciun serviciu
            asociat</h1>
        <p class="text-text-muted max-w-md">Contul tău nu este asociat cu niciun serviciu. Contactează echipa PitStop
            pentru a finaliza configurarea.</p>
        <a href="/contact"
           class="mt-2 bg-brand-red text-white font-bold px-6 py-3 rounded-lg text-sm hover:bg-brand-red-dark transition-colors">
            Contactează-ne
        </a>
    </div>
}
else
{
    <!-- Header -->
    <div class="bg-hero-dark text-white py-10 px-6 md:px-12">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
                <p class="text-xs text-white/40 uppercase tracking-widest font-bold mb-1">Dashboard serviciu</p>
                <h1 class="font-black text-3xl tracking-tight"
                    style="font-family: Manrope, sans-serif;">@_shop.Name</h1>
                <span class="inline-block mt-2 px-3 py-1 rounded-full text-xs font-bold @ShopStatusClass(_shop.Status)">
                    @ShopStatusLabel(_shop.Status)
                </span>
            </div>
            <a href="/serviciu/@_shop.Id" target="_blank"
               class="inline-flex items-center gap-2 border border-white/20 text-white px-4 py-2.5 rounded-lg text-sm font-bold hover:bg-white/10 transition-colors shrink-0">
                <span class="material-symbols-outlined text-base">open_in_new</span>
                Vizualizează profilul public
            </a>
        </div>
    </div>

    @if (_shop.Status == ShopStatus.Inactive)
    {
        <div class="max-w-7xl mx-auto px-6 md:px-12 mt-6">
            <div class="bg-brand-red-faint border-l-4 border-brand-red rounded-r-xl px-6 py-5 flex items-start gap-3">
                <span class="material-symbols-outlined text-brand-red mt-0.5">block</span>
                <div>
                    <h2 class="font-bold text-brand-red" style="font-family: Manrope, sans-serif;">Serviciul tău a fost
                        dezactivat</h2>
                    @if (_shop.DisabledReason is { Length: > 0 })
                    {
                        <p class="text-sm text-text-muted mt-1">Motiv: @_shop.DisabledReason</p>
                    }
                    <p class="text-sm text-text-muted mt-1">Contactează echipa PitStop pentru a clarifica situația.</p>
                </div>
            </div>
        </div>
    }

    <!-- Tab bar -->
    <div class="bg-white border-b border-border-light sticky top-0 z-10">
        <div class="max-w-7xl mx-auto px-6 md:px-12 flex gap-0 overflow-x-auto">
            @foreach (var (id, label) in new[] { ("profile", "Profil"), ("services", $"Servicii ({_services.Count})"), ("hours", "Program"), ("photos", $"Fotografii ({_photos.Count})"), ("reviews", $"Recenzii ({_reviewTotal})") })
            {
                <button @onclick="() => _tab = id"
                        class="px-5 py-4 text-sm font-semibold whitespace-nowrap border-b-2 transition-colors @(_tab == id ? "border-brand-red text-brand-red" : "border-transparent text-text-muted hover:text-text-main")">
                    @label
                </button>
            }
        </div>
    </div>

    <!-- Content -->
    <div class="max-w-7xl mx-auto px-6 md:px-12 py-8">

        @if (_tab == "profile")
        {
            <div class="max-w-2xl">
                <!-- Stats row -->
                <div class="grid grid-cols-3 gap-4 mb-6">
                    <div class="bg-white rounded-xl border border-border-light p-4 flex items-center gap-3">
                        <span class="material-symbols-outlined text-brand-red text-2xl">visibility</span>
                        <div>
                            <p class="text-xs text-text-muted">Vizualizări profil</p>
                            <p class="font-black text-xl text-text-main"
                               style="font-family: Manrope, sans-serif;">@_shop!.ViewCount</p>
                        </div>
                    </div>
                    <div class="bg-white rounded-xl border border-border-light p-4 flex items-center gap-3">
                        <span class="material-symbols-outlined text-brand-red text-2xl">star</span>
                        <div>
                            <p class="text-xs text-text-muted">Rating mediu</p>
                            <p class="font-black text-xl text-text-main"
                               style="font-family: Manrope, sans-serif;">@_shop.AverageRating.ToString("0.0")</p>
                        </div>
                    </div>
                    <div class="bg-white rounded-xl border border-border-light p-4 flex items-center gap-3">
                        <span class="material-symbols-outlined text-brand-red text-2xl">rate_review</span>
                        <div>
                            <p class="text-xs text-text-muted">Recenzii</p>
                            <p class="font-black text-xl text-text-main"
                               style="font-family: Manrope, sans-serif;">@_reviewTotal</p>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl border border-border-light p-6 md:p-8">
                    <h2 class="font-bold text-xl text-text-main mb-6" style="font-family: Manrope, sans-serif;">
                        Informații profil</h2>

                    <div class="flex flex-col gap-5">
                        <!-- Name -->
                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-text-main">Nume serviciu</label>
                            <input @bind="_pName" type="text"
                                   class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors"/>
                        </div>

                        <!-- Description -->
                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-text-main">Descriere</label>
                            <textarea @bind="_pDescription" rows="4"
                                      class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors resize-none"></textarea>
                        </div>

                        <!-- Address + City row -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-sm font-semibold text-text-main">Adresă</label>
                                <input @bind="_pAddress" type="text"
                                       class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors"/>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-sm font-semibold text-text-main">Oraș</label>
                                <input @bind="_pCity" type="text"
                                       class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors"/>
                            </div>
                        </div>

                        <!-- County + Sector row -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-sm font-semibold text-text-main">Județ</label>
                                <select @bind="_pCounty"
                                        class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors bg-white">
                                    <option value="">Selectează județul</option>
                                    @foreach (var county in All)
                                    {
                                        <option value="@county">@county</option>
                                    }
                                </select>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-sm font-semibold text-text-main">Sector (opțional)</label>
                                <input @bind="_pSector" type="text"
                                       class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors"/>
                            </div>
                        </div>

                        <!-- Phone + Email -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-sm font-semibold text-text-main">Telefon</label>
                                <input @bind="_pPhone" type="tel"
                                       class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors"/>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-sm font-semibold text-text-main">Email</label>
                                <input @bind="_pEmail" type="email"
                                       class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors"/>
                            </div>
                        </div>

                        <!-- Website -->
                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-text-main">Website (opțional)</label>
                            <input @bind="_pWebsite" type="url" placeholder="https://..."
                                   class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors"/>
                        </div>

                        <!-- Brands -->
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-text-main">Mărci cu care lucrezi</label>
                            @if (_brands.Count > 0)
                            {
                                <div class="flex flex-wrap gap-2">
                                    @foreach (var brand in _brands)
                                    {
                                        <span
                                            class="inline-flex items-center gap-1 bg-surface-container text-text-main text-sm px-3 py-1.5 rounded-full">
                                            @brand.Name
                                            <button @onclick="async () => await RemoveBrand(brand)"
                                                    class="text-text-muted hover:text-brand-red transition-colors ml-0.5">
                                                <span
                                                    class="material-symbols-outlined text-base leading-none">close</span>
                                            </button>
                                        </span>
                                    }
                                </div>
                            }
                            <div class="flex gap-2">
                                <input @bind="_newBrandName" @bind:event="oninput"
                                       placeholder="ex: BMW, Dacia, Toyota..."
                                       @onkeydown="HandleBrandKeyDown"
                                       class="flex-1 border border-border-light rounded-lg px-4 py-2 text-sm text-text-main focus:outline-none focus:ring-1 focus:ring-brand-red transition-colors"/>
                                <button @onclick="AddBrand" disabled="@(string.IsNullOrWhiteSpace(_newBrandName))"
                                        class="px-4 py-2 bg-brand-red text-white text-sm font-bold rounded-lg hover:bg-brand-red-dark disabled:opacity-50 transition-colors">
                                    Adaugă
                                </button>
                            </div>
                        </div>

                        @if (_profileSaved)
                        {
                            <div
                                class="flex items-center gap-2 bg-green-50 border border-green-200 rounded-lg px-4 py-3 text-sm text-green-700">
                                <span class="material-symbols-outlined text-lg">check_circle</span>
                                Profilul a fost salvat cu succes.
                            </div>
                        }

                        <button @onclick="SaveProfile" disabled="@_saving"
                                class="self-start bg-brand-red hover:bg-brand-red-dark disabled:opacity-50 text-white font-bold text-sm px-8 py-3 rounded-lg transition-colors">
                            @(_saving ? "Se salvează..." : "Salvează modificările")
                        </button>
                    </div>
                </div>
            </div>
        }
        else if (_tab == "services")
        {
            <div class="max-w-3xl flex flex-col gap-4">
                <!-- Add button -->
                <div class="flex justify-between items-center">
                    <h2 class="font-bold text-xl text-text-main" style="font-family: Manrope, sans-serif;">Servicii
                        oferite</h2>
                    <button @onclick="() => _isAdding = !_isAdding"
                            class="inline-flex items-center gap-2 bg-brand-red hover:bg-brand-red-dark text-white font-bold text-sm px-4 py-2.5 rounded-lg transition-colors">
                        <span class="material-symbols-outlined text-base">@(_isAdding ? "close" : "add")</span>
                        @(_isAdding ? "Anulează" : "Adaugă serviciu")
                    </button>
                </div>

                <!-- Add form -->
                @if (_isAdding)
                {
                    <div class="bg-white rounded-xl border-2 border-brand-red/30 p-6 flex flex-col gap-4">
                        <h3 class="font-bold text-text-main text-sm">Serviciu nou</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-semibold text-text-warm">Denumire *</label>
                                <input @bind="_newName" placeholder="ex: Schimb ulei"
                                       class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-semibold text-text-warm">Descriere</label>
                                <input @bind="_newDescription" placeholder="Scurtă descriere..."
                                       class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-semibold text-text-warm">Preț minim (RON)</label>
                                <input @bind="_newPriceMin" type="number" min="0" placeholder="0"
                                       class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-semibold text-text-warm">Preț maxim (RON)</label>
                                <input @bind="_newPriceMax" type="number" min="0" placeholder="0"
                                       class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                            </div>
                        </div>
                        <button @onclick="AddService" disabled="@(string.IsNullOrWhiteSpace(_newName))"
                                class="self-start bg-brand-red hover:bg-brand-red-dark disabled:opacity-50 text-white font-bold text-sm px-6 py-2.5 rounded-lg transition-colors">
                            Adaugă
                        </button>
                    </div>
                }

                <!-- Services list -->
                @if (_services.Count == 0)
                {
                    <div
                        class="bg-white rounded-xl border border-border-light flex flex-col items-center justify-center py-16 text-text-muted gap-2">
                        <span class="material-symbols-outlined text-4xl">build_circle</span>
                        <p class="text-sm">Niciun serviciu adăugat încă.</p>
                    </div>
                }
                else
                {
                    @foreach (var svc in _services)
                    {
                        <div class="bg-white rounded-xl border border-border-light p-5">
                            @if (svc.IsEditing)
                            {
                                <div class="flex flex-col gap-4">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <div class="flex flex-col gap-1.5">
                                            <label class="text-xs font-semibold text-text-warm">Denumire</label>
                                            <input @bind="svc.EditName"
                                                   class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                                        </div>
                                        <div class="flex flex-col gap-1.5">
                                            <label class="text-xs font-semibold text-text-warm">Descriere</label>
                                            <input @bind="svc.EditDescription"
                                                   class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                                        </div>
                                        <div class="flex flex-col gap-1.5">
                                            <label class="text-xs font-semibold text-text-warm">Preț minim (RON)</label>
                                            <input @bind="svc.EditPriceMin" type="number" min="0"
                                                   class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                                        </div>
                                        <div class="flex flex-col gap-1.5">
                                            <label class="text-xs font-semibold text-text-warm">Preț maxim (RON)</label>
                                            <input @bind="svc.EditPriceMax" type="number" min="0"
                                                   class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                                        </div>
                                    </div>
                                    <div class="flex gap-2">
                                        <button @onclick="async () => await SaveService(svc)"
                                                class="bg-brand-red hover:bg-brand-red-dark text-white font-bold text-sm px-5 py-2 rounded-lg transition-colors">
                                            Salvează
                                        </button>
                                        <button @onclick="svc.CancelEdit"
                                                class="border border-border-light text-text-muted hover:text-text-main text-sm font-bold px-5 py-2 rounded-lg transition-colors">
                                            Anulează
                                        </button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="font-bold text-text-main">@svc.Name</p>
                                        @if (svc.Description is { Length: > 0 })
                                        {
                                            <p class="text-sm text-text-muted mt-0.5">@svc.Description</p>
                                        }
                                        <p class="text-sm font-semibold text-brand-red mt-2">@FormatPrice(svc.PriceMin, svc.PriceMax)</p>
                                    </div>
                                    <div class="flex gap-2 shrink-0">
                                        <button @onclick="svc.BeginEdit"
                                                class="w-8 h-8 rounded-lg border border-border-light text-text-muted hover:text-text-main hover:bg-surface-container flex items-center justify-center transition-colors">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </button>
                                        <button @onclick="async () => await DeleteService(svc)"
                                                class="w-8 h-8 rounded-lg border border-red-200 text-brand-red hover:bg-brand-red-light flex items-center justify-center transition-colors">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }
        else if (_tab == "hours")
        {
            <div class="max-w-2xl">
                <div class="bg-white rounded-xl border border-border-light p-6 md:p-8">
                    <h2 class="font-bold text-xl text-text-main mb-6" style="font-family: Manrope, sans-serif;">Program
                        de funcționare</h2>

                    <div class="flex flex-col gap-3">
                        @foreach (var row in _hours)
                        {
                            <div class="flex items-center gap-4 py-3 border-b border-border-light last:border-b-0">
                                <span class="w-20 text-sm font-semibold text-text-main shrink-0">@row.DayName</span>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" @bind="row.IsClosed"
                                           class="h-4 w-4 rounded border-gray-300 text-brand-red focus:ring-brand-red"/>
                                    <span class="text-sm text-text-muted">Închis</span>
                                </label>
                                @if (!row.IsClosed)
                                {
                                    <div class="flex items-center gap-2 ml-auto">
                                        <input type="time" value="@row.OpenTime"
                                               @onchange="e => row.OpenTime = e.Value?.ToString() ?? string.Empty"
                                               class="border border-border-light rounded px-3 py-1.5 text-sm text-text-main focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                                        <span class="text-text-muted text-sm">–</span>
                                        <input type="time" value="@row.CloseTime"
                                               @onchange="e => row.CloseTime = e.Value?.ToString() ?? string.Empty"
                                               class="border border-border-light rounded px-3 py-1.5 text-sm text-text-main focus:outline-none focus:ring-1 focus:ring-brand-red"/>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (_hoursSaved)
                    {
                        <div
                            class="flex items-center gap-2 bg-green-50 border border-green-200 rounded-lg px-4 py-3 text-sm text-green-700 mt-5">
                            <span class="material-symbols-outlined text-lg">check_circle</span>
                            Programul a fost salvat cu succes.
                        </div>
                    }

                    <button @onclick="SaveHours" disabled="@_saving"
                            class="mt-6 bg-brand-red hover:bg-brand-red-dark disabled:opacity-50 text-white font-bold text-sm px-8 py-3 rounded-lg transition-colors">
                        @(_saving ? "Se salvează..." : "Salvează programul")
                    </button>
                </div>
            </div>
        }
        else if (_tab == "photos")
        {
            <!-- Photos tab -->
            <div class="max-w-3xl">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="font-bold text-xl text-text-main" style="font-family: Manrope, sans-serif;">
                        Fotografii</h2>
                    <label
                        class="inline-flex items-center gap-2 bg-brand-red hover:bg-brand-red-dark text-white font-bold text-sm px-4 py-2.5 rounded-lg transition-colors cursor-pointer @(_uploading ? "opacity-50 pointer-events-none" : "")">
                        <span
                            class="material-symbols-outlined text-base">@(_uploading ? "progress_activity" : "upload")</span>
                        @(_uploading ? "Se încarcă..." : "Adaugă fotografii")
                        <InputFile OnChange="HandlePhotoUpload" accept="image/*" multiple class="hidden"
                                   disabled="@_uploading"/>
                    </label>
                </div>

                @if (_uploadError is { Length: > 0 })
                {
                    <div
                        class="flex items-center gap-2 bg-brand-red-faint border border-red-200 rounded-lg px-4 py-3 text-sm text-brand-red mb-4">
                        <span class="material-symbols-outlined text-lg">error</span>
                        @_uploadError
                    </div>
                }

                @if (_photos.Count == 0)
                {
                    <div
                        class="bg-white rounded-xl border border-border-light flex flex-col items-center justify-center py-16 text-text-muted gap-2">
                        <span class="material-symbols-outlined text-4xl">photo_library</span>
                        <p class="text-sm">Nicio fotografie adăugată încă. Adaugă prima fotografie a serviciului
                            tău.</p>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                        @{ var orderedPhotos = _photos.OrderBy(p => p.DisplayOrder).ToList(); }
                        @for (var pi = 0; pi < orderedPhotos.Count; pi++)
                        {
                            var photo = orderedPhotos[pi];
                            var index = pi;
                            <div
                                class="relative group rounded-xl overflow-hidden border @(_shop!.CoverImage == photo.Url ? "border-brand-red ring-2 ring-brand-red" : "border-border-light")">
                                <img src="@photo.Url" alt="Fotografie serviciu" class="w-full h-44 object-cover"/>
                                @if (_shop!.CoverImage == photo.Url)
                                {
                                    <div
                                        class="absolute top-2 left-2 bg-brand-red text-white text-[10px] font-bold px-2 py-0.5 rounded">
                                        Copertă
                                    </div>
                                }
                                <!-- Reorder arrows (always visible on mobile, hover on desktop) -->
                                <div class="absolute top-2 right-2 flex gap-1">
                                    @if (index > 0)
                                    {
                                        <button @onclick="async () => await MovePhoto(index, -1)" title="Mută înainte"
                                                class="w-7 h-7 bg-white/90 rounded-full flex items-center justify-center text-text-main hover:bg-white shadow transition-colors">
                                            <span class="material-symbols-outlined text-sm">chevron_left</span>
                                        </button>
                                    }
                                    @if (index < orderedPhotos.Count - 1)
                                    {
                                        <button @onclick="async () => await MovePhoto(index, 1)" title="Mută înapoi"
                                                class="w-7 h-7 bg-white/90 rounded-full flex items-center justify-center text-text-main hover:bg-white shadow transition-colors">
                                            <span class="material-symbols-outlined text-sm">chevron_right</span>
                                        </button>
                                    }
                                </div>
                                <div
                                    class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-3">
                                    @if (_shop.CoverImage != photo.Url)
                                    {
                                        <button @onclick="async () => await SetCover(photo)"
                                                title="Setează ca fotografie principală"
                                                class="w-9 h-9 bg-white rounded-full flex items-center justify-center text-text-main hover:bg-brand-red hover:text-white transition-colors">
                                            <span class="material-symbols-outlined text-lg">star</span>
                                        </button>
                                    }
                                    <button @onclick="async () => await DeletePhoto(photo)" title="Șterge fotografia"
                                            class="w-9 h-9 bg-white rounded-full flex items-center justify-center text-brand-red hover:bg-brand-red hover:text-white transition-colors">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    <p class="text-xs text-text-muted mt-4">Fotografia marcată cu ★ apare ca imagine principală pe
                        profil. Folosește săgețile pentru a reordona fotografiile.</p>
                }
            </div>
        }
        else
        {
            <!-- Reviews tab -->
            @if (_reviews.Count == 0)
            {
                <div class="flex flex-col items-center justify-center py-16 text-text-muted gap-2">
                    <span class="material-symbols-outlined text-4xl">rate_review</span>
                    <p class="text-sm">Nicio recenzie primită încă.</p>
                </div>
            }
            else
            {
                <div class="max-w-2xl flex flex-col gap-4">
                    @foreach (var rev in _reviews)
                    {
                        <div class="bg-white rounded-xl border border-border-light p-5">
                            <div class="flex items-start justify-between gap-3 mb-3">
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-9 h-9 rounded-full bg-brand-red-faint text-brand-red flex items-center justify-center text-xs font-bold shrink-0">
                                        @rev.UserInitials
                                    </div>
                                    <div>
                                        <p class="font-semibold text-text-main text-sm">@rev.UserName</p>
                                        <p class="text-xs text-text-muted">@rev.CreatedAt.ToString("dd MMM yyyy")</p>
                                    </div>
                                </div>
                                <div class="flex gap-0.5 shrink-0">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        <span
                                            class="material-symbols-outlined text-base @(i <= rev.Rating ? "text-brand-red" : "text-gray-300")"
                                            style="font-variation-settings: 'FILL' 1;">star</span>
                                    }
                                </div>
                            </div>
                            <p class="text-sm text-text-muted leading-relaxed mb-4">@rev.Text</p>

                            <!-- Existing owner response -->
                            @if (rev.OwnerResponse is { Length: > 0 })
                            {
                                <div
                                    class="bg-surface-container border-l-4 border-brand-red rounded-r-lg px-4 py-3 mb-3">
                                    <p class="text-xs font-bold text-brand-red mb-1">Răspunsul proprietarului</p>
                                    <p class="text-sm text-text-main leading-relaxed">@rev.OwnerResponse</p>
                                    @if (rev.OwnerResponseAt.HasValue)
                                    {
                                        <p class="text-xs text-text-muted mt-1">@rev.OwnerResponseAt.Value.ToString("dd MMM yyyy")</p>
                                    }
                                </div>
                            }

                            <!-- Response form / toggle -->
                            @if (_respondingToId == rev.Id)
                            {
                                <div class="flex flex-col gap-2 mt-2">
                                    <textarea @bind="_responseText" rows="3"
                                              placeholder="Scrieți răspunsul dvs. la această recenzie..."
                                              class="border border-border-light rounded-lg px-3 py-2 text-sm text-text-main focus:outline-none focus:ring-1 focus:ring-brand-red resize-none"></textarea>
                                    <div class="flex gap-2">
                                        <button @onclick="async () => await SaveResponse(rev.Id)"
                                                disabled="@(string.IsNullOrWhiteSpace(_responseText))"
                                                class="bg-brand-red hover:bg-brand-red-dark disabled:opacity-50 text-white font-bold text-xs px-4 py-2 rounded-lg transition-colors">
                                            Publică răspunsul
                                        </button>
                                        @if (rev.OwnerResponse is { Length: > 0 })
                                        {
                                            <button @onclick="async () => await DeleteResponse(rev.Id)"
                                                    class="border border-red-200 text-brand-red hover:bg-brand-red-faint font-bold text-xs px-4 py-2 rounded-lg transition-colors">
                                                Șterge răspunsul
                                            </button>
                                        }
                                        <button @onclick='() => { _respondingToId = null; _responseText = ""; }'
                                                class="border border-border-light text-text-muted hover:text-text-main font-bold text-xs px-4 py-2 rounded-lg transition-colors">
                                            Anulează
                                        </button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <button
                                    @onclick='() => { _respondingToId = rev.Id; _responseText = rev.OwnerResponse ?? ""; }'
                                    class="flex items-center gap-1.5 text-xs font-semibold text-text-muted hover:text-brand-red transition-colors mt-1">
                                    <span class="material-symbols-outlined text-base">reply</span>
                                    @(rev.OwnerResponse is { Length: > 0 } ? "Editează răspunsul" : "Răspunde")
                                </button>
                            }
                        </div>
                    }

                    @if (_reviewTotal > _reviews.Count)
                    {
                        <button @onclick="LoadMoreReviews"
                                class="w-full py-3 border border-border-light rounded-xl text-sm font-semibold text-text-muted hover:bg-surface-container transition-colors">
                            Încarcă mai multe (@(_reviewTotal - _reviews.Count) rămase)
                        </button>
                    }
                </div>
            }
        }

    </div>
}

@code {
    private string _tab = "profile";
    private bool _loading = true;
    private bool _saving;
    private Shop? _shop;

    // Profile fields
    private string _pName = "";
    private string _pDescription = "";
    private string _pAddress = "";
    private string _pCity = "";
    private string _pCounty = "";
    private string _pSector = "";
    private string _pPhone = "";
    private string _pEmail = "";
    private string _pWebsite = "";
    private bool _profileSaved;

    // Services
    private List<ServiceRow> _services = [];
    private bool _isAdding;

    // Photos
    private List<ShopPhoto> _photos = [];
    private bool _uploading;
    private string _uploadError = string.Empty;

    // Brands
    private List<ShopBrand> _brands = [];
    private string _newBrandName = string.Empty;
    private string _newName = "";
    private string _newDescription = "";
    private decimal _newPriceMin;
    private decimal _newPriceMax;

    // Hours
    private List<HourRow> _hours = [];
    private bool _hoursSaved;
    private static readonly string[] DayNames = ["Luni", "Marți", "Miercuri", "Joi", "Vineri", "Sâmbătă", "Duminică"];

    // Reviews
    private List<Review> _reviews = [];
    private int _reviewTotal;
    private int _reviewPage = 1;
    private const int ReviewPageSize = 10;
    private int? _respondingToId;
    private string _responseText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!state.User.IsInRole("ShopOwner"))
        {
            Nav.NavigateTo("/auth/login", true);
            return;
        }

        var userId = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        _shop = await ShopRepo.GetByOwnerIdAsync(userId);

        if (_shop is not null)
        {
            PopulateProfileFields();
            _services = _shop.Services.Select(ServiceRow.FromEntity).ToList();
            _photos = _shop.Photos.OrderBy(p => p.DisplayOrder).ToList();
            _brands = _shop.Brands.ToList();
            InitHours();
            var (items, total) = await ReviewRepo.GetByShopIdAsync(_shop.Id, 1, ReviewPageSize);
            _reviews = items;
            _reviewTotal = total;
        }

        _loading = false;
    }

    private void PopulateProfileFields()
    {
        _pName = _shop!.Name;
        _pDescription = _shop.Description;
        _pAddress = _shop.Address;
        _pCity = _shop.City;
        _pCounty = _shop.County;
        _pSector = _shop.Sector ?? "";
        _pPhone = _shop.Phone;
        _pEmail = _shop.Email;
        _pWebsite = _shop.Website ?? "";
    }

    private void InitHours()
    {
        _hours = Enumerable.Range(0, 7).Select(i =>
        {
            var existing = _shop!.Hours.FirstOrDefault(h => h.DayOfWeek == i);
            return new HourRow
            {
                Day = i,
                DayName = DayNames[i],
                IsClosed = existing?.IsClosed ?? i >= 5,
                OpenTime = existing?.OpenTime?.ToString("HH:mm") ?? "09:00",
                CloseTime = existing?.CloseTime?.ToString("HH:mm") ?? "18:00"
            };
        }).ToList();
    }

    private async Task SaveProfile()
    {
        _saving = true;
        _profileSaved = false;
        await ShopRepo.UpdateProfileAsync(_shop!.Id, _pName, _pDescription, _pAddress,
            _pCity, _pCounty, _pPhone, _pEmail,
            string.IsNullOrWhiteSpace(_pWebsite) ? null : _pWebsite,
            string.IsNullOrWhiteSpace(_pSector) ? null : _pSector);
        _shop.Name = _pName;
        _saving = false;
        _profileSaved = true;
    }

    private async Task AddService()
    {
        var entity = new ShopService
        {
            ShopId = _shop!.Id,
            Name = _newName.Trim(),
            Description = _newDescription.Trim(),
            PriceMin = _newPriceMin,
            PriceMax = _newPriceMax
        };
        var saved = await ShopRepo.AddServiceAsync(entity);
        _services.Add(ServiceRow.FromEntity(saved));
        _newName = "";
        _newDescription = "";
        _newPriceMin = 0;
        _newPriceMax = 0;
        _isAdding = false;
    }

    private async Task SaveService(ServiceRow row)
    {
        var entity = new ShopService
        {
            Id = row.Id,
            ShopId = _shop!.Id,
            Name = row.EditName.Trim(),
            Description = row.EditDescription.Trim(),
            PriceMin = row.EditPriceMin,
            PriceMax = row.EditPriceMax
        };
        await ShopRepo.UpdateServiceAsync(entity);
        row.Apply();
    }

    private async Task DeleteService(ServiceRow row)
    {
        await ShopRepo.DeleteServiceAsync(row.Id);
        _services.Remove(row);
    }

    private async Task SaveHours()
    {
        _saving = true;
        _hoursSaved = false;
        var entities = _hours.Select(h => new ShopHour
        {
            DayOfWeek = h.Day,
            IsClosed = h.IsClosed,
            OpenTime = h.IsClosed ? null : TimeOnly.TryParse(h.OpenTime, out var ot) ? ot : null,
            CloseTime = h.IsClosed ? null : TimeOnly.TryParse(h.CloseTime, out var ct) ? ct : null
        }).ToList();
        await ShopRepo.UpsertHoursAsync(_shop!.Id, entities);
        _saving = false;
        _hoursSaved = true;
    }

    private async Task AddBrand()
    {
        var name = _newBrandName.Trim();
        if (string.IsNullOrEmpty(name) || _brands.Any(b => b.Name.Equals(name, StringComparison.OrdinalIgnoreCase)))
        {
            _newBrandName = string.Empty;
            return;
        }

        var brand = await ShopRepo.AddBrandAsync(new ShopBrand { ShopId = _shop!.Id, Name = name });
        _brands.Add(brand);
        _newBrandName = string.Empty;
    }

    private async Task RemoveBrand(ShopBrand brand)
    {
        await ShopRepo.DeleteBrandAsync(brand.Id);
        _brands.Remove(brand);
    }

    private async Task HandleBrandKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddBrand();
    }

    private async Task HandlePhotoUpload(InputFileChangeEventArgs e)
    {
        _uploading = true;
        _uploadError = string.Empty;
        try
        {
            foreach (var file in e.GetMultipleFiles())
            {
                if (file.Size > 5 * 1024 * 1024)
                {
                    _uploadError = $"'{file.Name}' depășește limita de 5 MB.";
                    continue;
                }

                await using var stream = file.OpenReadStream(5 * 1024 * 1024);
                var url = await FileStorage.UploadAsync(stream, file.Name, "shops");
                var photo = await ShopRepo.AddPhotoAsync(new ShopPhoto { ShopId = _shop!.Id, Url = url });
                _photos.Add(photo);

                if (string.IsNullOrEmpty(_shop!.CoverImage))
                {
                    await ShopRepo.SetCoverImageAsync(_shop.Id, url);
                    _shop.CoverImage = url;
                }
            }
        }
        catch
        {
            _uploadError = "A apărut o eroare la încărcarea fotografiei.";
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task DeletePhoto(ShopPhoto photo)
    {
        await ShopRepo.DeletePhotoAsync(photo.Id);
        await FileStorage.DeleteAsync(photo.Url);
        _photos.Remove(photo);

        if (_shop!.CoverImage == photo.Url)
        {
            var newCover = _photos.OrderBy(p => p.DisplayOrder).FirstOrDefault()?.Url;
            await ShopRepo.SetCoverImageAsync(_shop.Id, newCover);
            _shop.CoverImage = newCover;
        }
    }

    private async Task SetCover(ShopPhoto photo)
    {
        await ShopRepo.SetCoverImageAsync(_shop!.Id, photo.Url);
        _shop.CoverImage = photo.Url;
    }

    private async Task LoadMoreReviews()
    {
        _reviewPage++;
        var (items, _) = await ReviewRepo.GetByShopIdAsync(_shop!.Id, _reviewPage, ReviewPageSize);
        _reviews.AddRange(items);
    }

    private async Task MovePhoto(int index, int direction)
    {
        var ordered = _photos.OrderBy(p => p.DisplayOrder).ToList();
        var swapIndex = index + direction;
        if (swapIndex < 0 || swapIndex >= ordered.Count) return;

        (ordered[index].DisplayOrder, ordered[swapIndex].DisplayOrder) =
            (ordered[swapIndex].DisplayOrder, ordered[index].DisplayOrder);

        await ShopRepo.UpdatePhotoOrderAsync(
            ordered.Select(p => (p.Id, p.DisplayOrder)).ToList());
    }

    private async Task SaveResponse(int reviewId)
    {
        var text = _responseText.Trim();
        if (string.IsNullOrEmpty(text)) return;
        await ReviewRepo.SetOwnerResponseAsync(reviewId, text);
        var rev = _reviews.FirstOrDefault(r => r.Id == reviewId);
        if (rev is not null)
        {
            rev.OwnerResponse = text;
            rev.OwnerResponseAt = DateTime.UtcNow;
        }

        _respondingToId = null;
        _responseText = string.Empty;
    }

    private async Task DeleteResponse(int reviewId)
    {
        await ReviewRepo.SetOwnerResponseAsync(reviewId, null);
        var rev = _reviews.FirstOrDefault(r => r.Id == reviewId);
        if (rev is not null)
        {
            rev.OwnerResponse = null;
            rev.OwnerResponseAt = null;
        }

        _respondingToId = null;
        _responseText = string.Empty;
    }

    private static string FormatPrice(decimal min, decimal max)
    {
        if (min == 0 && max == 0) return "La cerere";
        if (min == max || max == 0) return $"{min:0} RON";
        return $"{min:0} – {max:0} RON";
    }

    private static string ShopStatusClass(ShopStatus s)
    {
        return s switch
        {
            ShopStatus.Active => "bg-green-900/30 text-green-300",
            ShopStatus.Pending => "bg-orange-900/30 text-orange-300",
            ShopStatus.Inactive => "bg-white/10 text-white/50",
            _ => "bg-white/10 text-white/50"
        };
    }

    private static string ShopStatusLabel(ShopStatus s)
    {
        return s switch
        {
            ShopStatus.Active => "Activ",
            ShopStatus.Pending => "În verificare",
            ShopStatus.Inactive => "Inactiv",
            _ => s.ToString()
        };
    }

    private class ServiceRow
    {
        public int Id { get; init; }
        public bool IsEditing { get; set; }
        public string Name { get; private set; } = "";
        public string Description { get; private set; } = "";
        public decimal PriceMin { get; private set; }
        public decimal PriceMax { get; private set; }
        public string EditName { get; set; } = "";
        public string EditDescription { get; set; } = "";
        public decimal EditPriceMin { get; set; }
        public decimal EditPriceMax { get; set; }

        public static ServiceRow FromEntity(ShopService s)
        {
            return new ServiceRow
            {
                Id = s.Id,
                Name = s.Name,
                Description = s.Description,
                PriceMin = s.PriceMin,
                PriceMax = s.PriceMax
            };
        }

        public void BeginEdit()
        {
            EditName = Name;
            EditDescription = Description;
            EditPriceMin = PriceMin;
            EditPriceMax = PriceMax;
            IsEditing = true;
        }

        public void CancelEdit()
        {
            IsEditing = false;
        }

        public void Apply()
        {
            Name = EditName;
            Description = EditDescription;
            PriceMin = EditPriceMin;
            PriceMax = EditPriceMax;
            IsEditing = false;
        }
    }

    private class HourRow
    {
        public int Day { get; init; }
        public string DayName { get; init; } = "";
        public bool IsClosed { get; set; }
        public string OpenTime { get; set; } = "09:00";
        public string CloseTime { get; set; } = "18:00";
    }

}
