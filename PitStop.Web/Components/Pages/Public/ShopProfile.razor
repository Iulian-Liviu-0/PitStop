@page "/serviciu/{Id:int}"
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer
@inject IShopRepository ShopRepo
@inject IFavoriteShopRepository FavoriteRepo
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>@(Shop is null ? "PitStop" : $"{Shop.Name} — {Shop.Category} în {Shop.City} | PitStop")</PageTitle>
@if (Shop is not null)
{
    var absImage = Shop.CoverImage.StartsWith("http") ? Shop.CoverImage : $"{Nav.BaseUri.TrimEnd('/')}{Shop.CoverImage}";
    var metaDesc = Shop.Description.Length > 155 ? Shop.Description[..155] + "…" : Shop.Description;
    <HeadContent>
        <meta name="description" content="@metaDesc"/>
        <meta property="og:type" content="business.business"/>
        <meta property="og:title" content="@Shop.Name | PitStop"/>
        <meta property="og:description" content="@metaDesc"/>
        <meta property="og:image" content="@absImage"/>
        <meta property="og:url" content="@Nav.Uri"/>
        <meta property="og:locale" content="ro_RO"/>
        <meta name="twitter:card" content="summary_large_image"/>
        <meta name="twitter:title" content="@Shop.Name | PitStop"/>
        <meta name="twitter:description" content="@metaDesc"/>
        <meta name="twitter:image" content="@absImage"/>
        <link rel="canonical" href="@Nav.Uri"/>
        @((MarkupString)BuildJsonLd())
    </HeadContent>
}

@if (Shop is null)
{
    <div class="min-h-screen bg-surface flex items-center justify-center pt-20">
        <p class="text-text-muted">Se încarcă...</p>
    </div>
}
else
{
    <div class="bg-surface-bright min-h-screen">

        <ShopHeroBanner Shop="Shop" IsFavorite="_isFavorite" IsTogglingFavorite="_togglingFavorite"
                        PageUrl="@Nav.Uri" OnToggleFavorite="ToggleFavorite"/>

        <div class="max-w-7xl mx-auto px-6 py-12">
            <div class="flex flex-col lg:flex-row gap-8">

                <div class="lg:w-2/3 space-y-8">
                    <ShopAboutCard Description="@Shop.Description" Brands="Shop.Brands"/>
                    <ShopServicesCard Services="Shop.Services"/>
                    <ShopGallery Photos="Shop.Photos"/>
                    <ShopReviewsSection ShopId="Id" ShopName="@Shop.Name"
                                        Reviews="Shop.Reviews" RatingBars="RatingBars"
                                        OverallRating="Shop.Rating" TotalCount="Shop.ReviewCount"
                                        IsAuthenticated="_isAuthenticated" UserId="@_userId"
                                        UserDisplayName="@_userDisplayName" UserInitials="@_userInitials"
                                        OnReviewSubmitted="LoadShop"/>
                </div>

                <div class="lg:w-1/3">
                    <div class="sticky top-24 space-y-6">
                        <ShopContactCard Phone="@Shop.Phone" Email="@Shop.Email"
                                         Website="@Shop.Website" Address="@Shop.Address"/>
                        <ShopHoursCard Hours="Shop.Hours"/>
                        <ShopLocationCard Address="@Shop.Address"/>
                        <button @onclick='() => _reportOpen = true'
                                class="w-full flex items-center justify-center gap-1.5 py-1 text-text-muted hover:text-brand-red transition-colors text-xs font-medium">
                            <span class="material-symbols-outlined text-base">flag</span>
                            Raportează o problemă cu acest profil
                        </button>
                    </div>
                </div>
            </div>

            <ShopSimilarSection SimilarShops="SimilarShops" City="@Shop.City"/>
        </div>
    </div>

    <ReportModal IsOpen="_reportOpen" OnClose='() => _reportOpen = false'/>
}

@code {
    [Parameter] public int Id { get; set; }

    private ShopProfileData? Shop;
    private List<RatingBar> RatingBars = [];
    private List<SimilarShop> SimilarShops = [];
    private int _loadedId;

    private string _userId = string.Empty;
    private string _userDisplayName = string.Empty;
    private string _userInitials = string.Empty;
    private bool _isAuthenticated;

    private bool _isFavorite;
    private bool _togglingFavorite;
    private bool _reportOpen;

    private static readonly string[] DayNames = ["Luni", "Marți", "Miercuri", "Joi", "Vineri", "Sâmbătă", "Duminică"];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
        {
            _isAuthenticated = true;
            _userId = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
            var appUser = await UserManager.FindByIdAsync(_userId);
            _userDisplayName = appUser?.FullName ?? "Utilizator";
            _userInitials = Initials(_userDisplayName);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id == _loadedId) return;
        _loadedId = Id;
        await LoadShop();
    }

    private async Task LoadShop()
    {
        Shop = null;
        var shop = await ShopRepo.GetByIdAsync(Id);
        if (shop is null)
        {
            Nav.NavigateTo("/not-found");
            return;
        }

        _ = ShopRepo.IncrementViewCountAsync(Id);

        // .NET DayOfWeek is Sunday=0; project convention is Monday=0, so shift by 6
        var today = ((int)DateTime.UtcNow.DayOfWeek + 6) % 7;
        var (isOpen, closingTime) = GetOpenStatus(shop.Hours, today);

        Shop = new ShopProfileData(
            shop.Name,
            CategoryDisplayName(shop.Category),
            shop.City,
            shop.County,
            shop.Address,
            shop.Phone,
            shop.Email,
            shop.Website ?? string.Empty,
            Math.Round(shop.AverageRating, 1),
            shop.ReviewCount,
            isOpen,
            closingTime,
            shop.CoverImage ?? shop.Photos.FirstOrDefault()?.Url ?? string.Empty,
            shop.Description,
            shop.Brands.Select(b => b.Name).ToList(),
            shop.Services.Select(s => new ServiceItem(
                s.Name, s.Description, FormatPrice(s.PriceMin, s.PriceMax))).ToList(),
            shop.Photos.Select(p => p.Url).ToList(),
            shop.Reviews.Select(r => new ReviewItem(
                r.Id, r.UserName, r.UserInitials, r.Rating, FormatDate(r.CreatedAt), r.Text, r.UsefulCount,
                r.OwnerResponse,
                r.OwnerResponseAt.HasValue ? FormatDate(r.OwnerResponseAt.Value) : null)).ToList(),
            shop.Hours.OrderBy(h => h.DayOfWeek).Select(h => new HourItem(
                DayNames[h.DayOfWeek],
                h.OpenTime?.ToString("HH:mm") ?? string.Empty,
                h.CloseTime?.ToString("HH:mm") ?? string.Empty,
                h.IsClosed,
                h.DayOfWeek == today)).ToList()
        );

        RatingBars = BuildRatingBars(shop.Reviews);

        var favoriteTask = _isAuthenticated && !string.IsNullOrEmpty(_userId)
            ? FavoriteRepo.IsFavoriteAsync(_userId, Id)
            : Task.FromResult(false);
        var similarTask = ShopRepo.SearchAsync(string.Empty, string.Empty, shop.Category, null, null, 1, 4);

        await Task.WhenAll(favoriteTask, similarTask);

        _isFavorite = favoriteTask.Result;
        SimilarShops = similarTask.Result.Items
            .Where(s => s.Id != Id)
            .Take(3)
            .Select(s => new SimilarShop(
                s.Id, s.Name, s.Sector ?? s.City,
                Math.Round(s.AverageRating, 1), s.ReviewCount,
                s.Photos.FirstOrDefault()?.Url ?? string.Empty,
                [CategoryDisplayName(s.Category)]))
            .ToList();
    }

    private async Task ToggleFavorite()
    {
        if (!_isAuthenticated)
        {
            Nav.NavigateTo("/auth/login", true);
            return;
        }

        _togglingFavorite = true;
        if (_isFavorite)
            await FavoriteRepo.RemoveAsync(_userId, Id);
        else
            await FavoriteRepo.AddAsync(_userId, Id);
        _isFavorite = !_isFavorite;
        _togglingFavorite = false;
    }

    private static (bool IsOpen, string ClosingTime) GetOpenStatus(ICollection<ShopHour> hours, int today)
    {
        var now = TimeOnly.FromDateTime(DateTime.UtcNow);
        var h = hours.FirstOrDefault(h => h.DayOfWeek == today);
        if (h is null || h.IsClosed || h.OpenTime is null || h.CloseTime is null) return (false, string.Empty);
        return (h.OpenTime <= now && now <= h.CloseTime, h.CloseTime.Value.ToString("HH:mm"));
    }

    private static List<RatingBar> BuildRatingBars(ICollection<Review> reviews)
    {
        var total = reviews.Count;
        if (total == 0) return [new RatingBar(5, 0), new RatingBar(4, 0), new RatingBar(3, 0), new RatingBar(2, 0), new RatingBar(1, 0)];
        return Enumerable.Range(1, 5).Reverse()
            .Select(s => new RatingBar(s, (int)Math.Round(reviews.Count(r => r.Rating == s) * 100.0 / total)))
            .ToList();
    }

    private static string FormatPrice(decimal min, decimal max)
    {
        return (min, max) switch
        {
            (0, 0) => "La cerere",
            var (a, b) when a == b => $"{a:N0} RON",
            _ => $"{min:N0} – {max:N0} RON"
        };
    }

    private static string FormatDate(DateTime date)
    {
        var days = (DateTime.UtcNow - date).TotalDays;
        if (days < 1) return "Astăzi";
        if (days < 2) return "Ieri";
        if (days < 7) return $"Acum {(int)days} zile";
        if (days < 30) return $"Acum {(int)(days / 7)} săptămâni";
        if (days < 365) return $"Acum {(int)(days / 30)} luni";
        return $"Acum {(int)(days / 365)} ani";
    }

    private string BuildJsonLd()
    {
        if (Shop is null) return string.Empty;
        var absImage = Shop.CoverImage.StartsWith("http")
            ? Shop.CoverImage
            : $"{Nav.BaseUri.TrimEnd('/')}{Shop.CoverImage}";

        // Use variables for @-prefixed keys — Razor parser misreads @ in string literals
        const string atType = "@type";
        const string atContext = "@context";
        var data = new Dictionary<string, object>
        {
            [atContext] = "https://schema.org",
            [atType] = "AutoRepair",
            ["name"] = Shop.Name,
            ["description"] = Shop.Description,
            ["image"] = absImage,
            ["url"] = Nav.Uri,
            ["telephone"] = Shop.Phone,
            ["address"] = new Dictionary<string, string>
            {
                [atType] = "PostalAddress",
                ["streetAddress"] = Shop.Address,
                ["addressLocality"] = Shop.City,
                ["addressRegion"] = Shop.County,
                ["addressCountry"] = "RO"
            },
            ["aggregateRating"] = new Dictionary<string, object>
            {
                [atType] = "AggregateRating",
                ["ratingValue"] = Shop.Rating,
                ["reviewCount"] = Shop.ReviewCount
            }
        };

        var json = JsonSerializer.Serialize(data);
        // Use concatenation — Razor parser misreads <script> tag in string interpolation
        return "<script type=\"application/ld+json\">" + json + "</script>";
    }

}
