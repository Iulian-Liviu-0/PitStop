@page "/not-found"
@layout MainLayout

<PageTitle>Pagina nu a fost găsită - PitStop</PageTitle>

<section class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6 py-24">
    <span class="material-symbols-outlined text-8xl text-border-light mb-6">search_off</span>
    <h1 class="font-black text-6xl text-text-main mb-4" style="font-family: Manrope, sans-serif;">404</h1>
    <p class="text-xl text-text-muted mb-8 max-w-md">
        Pagina pe care o cauți nu există sau a fost mutată.
    </p>
    <a href="/"
       class="bg-brand-red hover:bg-brand-red-dark text-white font-bold px-8 py-3 rounded-lg transition-colors shadow-sm">
        Înapoi acasă
    </a>
</section>
