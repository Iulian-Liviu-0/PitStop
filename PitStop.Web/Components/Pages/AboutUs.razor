@page "/despre-noi"
@rendermode InteractiveServer
@inject IShopRepository ShopRepo

<PageTitle>Despre Noi - PitStop</PageTitle>

<!-- ─── HERO ─── -->
<section class="relative bg-hero-dark text-white py-28 px-6 md:px-12 flex flex-col items-center text-center overflow-hidden min-h-[480px] justify-center">
    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAHOeMUGgLDTzCkVUfyiaa3xeRbQPX59ydr4kbpCbl52bhmye9bGe0R9F8tvdOlTiz80Tcp5eCva1fdeVlmdd2S_sHvcC_FiS2Qv16mWf5pPv287ZXvu8ZUZP-P183lC_oPKm1CXPkT8PK6jSvYjwSxcEZMPNES7SjdmWwyLz4ESR-Dmj_KUf2zCHZs7YjgYie9XCe4OIBJZtdsVHg0Kb0WkV2oYjmQsPAvDji8AMWm0WNiIXTu_TPJc7xNsl8XVU9S6QIKhk8-FdRg"
         alt=""
         class="absolute inset-0 w-full h-full object-cover opacity-15 z-0" />
    <div class="absolute inset-0 bg-gradient-to-b from-hero-dark/60 to-hero-dark/80 z-0"></div>
    <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center gap-6">
        <span class="inline-block px-5 py-1.5 rounded-full bg-white/10 border border-white/20 text-white text-xs font-bold tracking-widest uppercase">
            Povestea noastră
        </span>
        <h1 class="font-black text-4xl md:text-6xl tracking-tight leading-tight" style="font-family: Manrope, sans-serif;">
            Conectăm șoferii români cu cei mai buni specialiști auto și moto
        </h1>
        <p class="text-lg md:text-xl text-white/70 max-w-2xl leading-relaxed">
            PitStop a luat naștere dintr-o nevoie reală — găsirea unui service auto sau moto de încredere în România nu ar trebui să fie complicată.
        </p>
    </div>
</section>

<!-- ─── MISSION & VISION ─── -->
<section class="bg-surface-bright py-20 px-6 md:px-12">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">

        <div class="bg-white rounded-xl p-10 border border-border-light flex flex-col gap-5">
            <div class="w-14 h-14 bg-brand-red-faint rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl text-brand-red" style="font-variation-settings: 'FILL' 1;">flag</span>
            </div>
            <div>
                <h2 class="font-bold text-xl text-text-main mb-3" style="font-family: Manrope, sans-serif;">Misiunea Noastră</h2>
                <p class="text-text-muted leading-relaxed text-sm">
                    Ne propunem să ajutăm șoferii și motocicliștii din România să găsească rapid și ușor servicii de încredere — transparent și fără bătăi de cap.
                </p>
            </div>
        </div>

        <div class="bg-white rounded-xl p-10 border border-border-light flex flex-col gap-5">
            <div class="w-14 h-14 bg-secondary-light rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl text-secondary" style="font-variation-settings: 'FILL' 1;">visibility</span>
            </div>
            <div>
                <h2 class="font-bold text-xl text-text-main mb-3" style="font-family: Manrope, sans-serif;">Viziunea Noastră</h2>
                <p class="text-text-muted leading-relaxed text-sm">
                    Să devenim platforma #1 din România pentru tot ecosistemul de servicii auto și moto, unind cererea cu calitatea sub același acoperiș digital.
                </p>
            </div>
        </div>

    </div>
</section>

<StatsSection Large="true" TotalShops="_statsShopCount" TotalCounties="_statsCountyCount" AvgRating="_statsAvgRating" TotalReviews="_statsReviewCount" />

<!-- ─── HOW WE WORK ─── -->
<section class="bg-surface-bright py-24 px-6 md:px-12">
    <div class="max-w-screen-xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="font-bold text-3xl md:text-4xl text-text-main mb-4" style="font-family: Manrope, sans-serif;">Cum funcționăm</h2>
            <p class="text-text-muted max-w-2xl mx-auto">
                Ne asigurăm că standardele noastre de calitate rămân ridicate prin procese stricte și feedback continuu.
            </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

            <div class="flex flex-col items-center text-center gap-5">
                <div class="w-20 h-20 rounded-full bg-surface-container flex items-center justify-center relative">
                    <span class="absolute -top-2 -right-2 w-8 h-8 rounded-full bg-brand-red text-white flex items-center justify-center font-bold text-sm" style="font-family: Manrope, sans-serif;">1</span>
                    <span class="material-symbols-outlined text-3xl text-text-main">verified</span>
                </div>
                <div>
                    <h3 class="font-bold text-lg text-text-main mb-2" style="font-family: Manrope, sans-serif;">Verificăm fiecare serviciu</h3>
                    <p class="text-text-muted text-sm">Analizăm documentația și prezența online înainte de aprobare.</p>
                </div>
            </div>

            <div class="flex flex-col items-center text-center gap-5">
                <div class="w-20 h-20 rounded-full bg-surface-container flex items-center justify-center relative">
                    <span class="absolute -top-2 -right-2 w-8 h-8 rounded-full bg-brand-red text-white flex items-center justify-center font-bold text-sm" style="font-family: Manrope, sans-serif;">2</span>
                    <span class="material-symbols-outlined text-3xl text-text-main">forum</span>
                </div>
                <div>
                    <h3 class="font-bold text-lg text-text-main mb-2" style="font-family: Manrope, sans-serif;">Recenzii reale</h3>
                    <p class="text-text-muted text-sm">Doar utilizatorii cu cont pot lăsa recenzii detaliate.</p>
                </div>
            </div>

            <div class="flex flex-col items-center text-center gap-5">
                <div class="w-20 h-20 rounded-full bg-surface-container flex items-center justify-center relative">
                    <span class="absolute -top-2 -right-2 w-8 h-8 rounded-full bg-brand-red text-white flex items-center justify-center font-bold text-sm" style="font-family: Manrope, sans-serif;">3</span>
                    <span class="material-symbols-outlined text-3xl text-text-main">update</span>
                </div>
                <div>
                    <h3 class="font-bold text-lg text-text-main mb-2" style="font-family: Manrope, sans-serif;">Actualizăm constant</h3>
                    <p class="text-text-muted text-sm">Informațiile sunt verificate periodic pentru a asigura acuratețea.</p>
                </div>
            </div>

        </div>
    </div>
</section>

<TeamSection />

<CTASection Variant="CTASection.CTAVariant.RedCentered"
            Title="Ai un service auto sau moto?"
            Subtitle="Alătură-te rețelei PitStop și conectează-te cu mii de clienți din toată România."
            ButtonText="Listează-ți serviciul" />

@code {
    private int? _statsShopCount;
    private int? _statsCountyCount;
    private double? _statsAvgRating;
    private int? _statsReviewCount;

    protected override async Task OnInitializedAsync()
    {
        var (shopCount, countyCount, avgRating, reviewCount) = await ShopRepo.GetSiteStatsAsync();
        _statsShopCount = shopCount;
        _statsCountyCount = countyCount;
        _statsAvgRating = avgRating;
        _statsReviewCount = reviewCount;
    }
}
