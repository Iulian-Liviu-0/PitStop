@page "/admin"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IShopRepository ShopRepo
@inject IShopRequestRepository RequestRepo
@inject IReviewRepository ReviewRepo
@inject UserManager<ApplicationUser> UserMgr
@inject IEmailService EmailSvc
@inject IJSRuntime JS

<PageTitle>Admin - PitStop</PageTitle>

<!-- Header -->
<div class="bg-hero-dark text-white py-10 px-6 md:px-12">
    <div class="max-w-screen-xl mx-auto flex items-center justify-between">
        <div>
            <p class="text-xs text-white/40 uppercase tracking-widest font-bold mb-1">Panou de administrare</p>
            <h1 class="font-black text-3xl tracking-tight" style="font-family: Manrope, sans-serif;">PitStop Admin</h1>
            @if (_isSuperAdmin)
            {
                <span class="mt-2 inline-block px-2.5 py-1 bg-brand-red text-white text-xs font-bold rounded-full">Super Admin</span>
            }
        </div>
        <span class="material-symbols-outlined text-6xl text-white/20">admin_panel_settings</span>
    </div>
</div>

<!-- Stats -->
<div class="bg-surface-container border-b border-border-light">
    <div class="max-w-screen-xl mx-auto px-6 md:px-12 py-6 grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl p-5 border border-border-light flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-brand-red-faint flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-brand-red text-xl">store</span>
            </div>
            <div>
                <p class="text-xs text-text-muted">Servicii Active</p>
                <p class="text-2xl font-black text-text-main" style="font-family: Manrope, sans-serif;">@_activeShops</p>
            </div>
        </div>
        <div class="bg-white rounded-xl p-5 border border-border-light flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-orange-50 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-orange-500 text-xl">inbox</span>
            </div>
            <div>
                <p class="text-xs text-text-muted">Cereri Noi</p>
                <p class="text-2xl font-black text-orange-500" style="font-family: Manrope, sans-serif;">@_pendingCount</p>
            </div>
        </div>
        <div class="bg-white rounded-xl p-5 border border-border-light flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-secondary-light flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-secondary text-xl">group</span>
            </div>
            <div>
                <p class="text-xs text-text-muted">Utilizatori</p>
                <p class="text-2xl font-black text-text-main" style="font-family: Manrope, sans-serif;">@_userCount</p>
            </div>
        </div>
        <div class="bg-white rounded-xl p-5 border border-border-light flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-surface-low flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-brand-blue text-xl">rate_review</span>
            </div>
            <div>
                <p class="text-xs text-text-muted">Recenzii</p>
                <p class="text-2xl font-black text-text-main" style="font-family: Manrope, sans-serif;">@_reviewCount</p>
            </div>
        </div>
    </div>
</div>

<!-- Tab bar -->
<div class="bg-white border-b border-border-light sticky top-0 z-10">
    <div class="max-w-screen-xl mx-auto px-6 md:px-12 flex gap-0 overflow-x-auto">
        @foreach (var (id, label) in Tabs)
        {
            <button @onclick="async () => await SwitchTab(id)"
                    class="px-5 py-4 text-sm font-semibold whitespace-nowrap border-b-2 transition-colors @(_tab == id ? "border-brand-red text-brand-red" : "border-transparent text-text-muted hover:text-text-main")">
                @label
            </button>
        }
    </div>
</div>

<!-- Content -->
<div class="max-w-screen-xl mx-auto px-6 md:px-12 py-8">

    @if (_tab == "requests")
    {
        <div class="bg-white rounded-xl border border-border-light overflow-hidden">
            <div class="px-6 py-4 border-b border-border-light flex items-center justify-between">
                <h2 class="font-bold text-text-main" style="font-family: Manrope, sans-serif;">Toate cererile</h2>
                <span class="text-sm text-text-muted">@_requests.Count înregistrări</span>
            </div>
            @if (_requests.Count == 0)
            {
                <div class="flex flex-col items-center justify-center py-16 text-text-muted gap-2">
                    <span class="material-symbols-outlined text-4xl">inbox</span>
                    <p class="text-sm">Nicio cerere primită încă.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-surface-container text-text-warm text-xs uppercase tracking-wide">
                            <tr>
                                <th class="px-5 py-3 text-left font-semibold">Serviciu</th>
                                <th class="px-5 py-3 text-left font-semibold">Categorie</th>
                                <th class="px-5 py-3 text-left font-semibold">Oraș</th>
                                <th class="px-5 py-3 text-left font-semibold">Contact</th>
                                <th class="px-5 py-3 text-left font-semibold">Data</th>
                                <th class="px-5 py-3 text-left font-semibold">Status</th>
                                <th class="px-5 py-3 text-left font-semibold">Acțiuni</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-light">
                            @foreach (var req in _requests)
                            {
                                <tr class="hover:bg-surface-container/50 transition-colors">
                                    <td class="px-5 py-4 font-semibold text-text-main">@req.ShopName</td>
                                    <td class="px-5 py-4 text-text-muted">@CategoryLabel(req.Category)</td>
                                    <td class="px-5 py-4 text-text-muted">@req.City</td>
                                    <td class="px-5 py-4">
                                        <p class="font-medium text-text-main">@req.ContactPerson</p>
                                        <p class="text-text-muted text-xs">@req.Email</p>
                                    </td>
                                    <td class="px-5 py-4 text-text-muted text-xs">@req.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td class="px-5 py-4">
                                        <span class="px-2.5 py-1 rounded-full text-xs font-bold @RequestStatusClass(req.Status)">
                                            @RequestStatusLabel(req.Status)
                                        </span>
                                    </td>
                                    <td class="px-5 py-4">
                                        @if (req.Status == ShopRequestStatus.Pending)
                                        {
                                            <div class="flex flex-col gap-2">
                                                <div class="flex gap-2">
                                                    <button @onclick="async () => await ApproveRequest(req.Id)"
                                                            class="px-3 py-1.5 bg-green-500 hover:bg-green-600 text-white text-xs font-bold rounded transition-colors">
                                                        Aprobă
                                                    </button>
                                                    <button @onclick='() => { _rejectingId = _rejectingId == req.Id ? null : req.Id; _rejectNote = req.AdminNote ?? ""; }'
                                                            class="px-3 py-1.5 bg-brand-red hover:bg-brand-red-dark text-white text-xs font-bold rounded transition-colors">
                                                        Respinge
                                                    </button>
                                                </div>
                                                @if (_rejectingId == req.Id)
                                                {
                                                    <div class="flex flex-col gap-1.5 mt-1">
                                                        <input @bind="_rejectNote" placeholder="Notă opțională..."
                                                               class="border border-border-light rounded px-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-brand-red text-text-main" />
                                                        <button @onclick="async () => await RejectRequest(req.Id)"
                                                                class="px-3 py-1.5 bg-brand-red hover:bg-brand-red-dark text-white text-xs font-bold rounded transition-colors">
                                                            Confirmă respingerea
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else if (req.AdminNote is { Length: > 0 })
                                        {
                                            <p class="text-xs text-text-muted italic max-w-[180px]">@req.AdminNote</p>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
    else if (_tab == "shops")
    {
        <div class="bg-white rounded-xl border border-border-light overflow-hidden">
            <div class="px-6 py-4 border-b border-border-light flex items-center justify-between flex-wrap gap-3">
                <h2 class="font-bold text-text-main" style="font-family: Manrope, sans-serif;">Toate serviciile</h2>
                <input @bind="_shopSearch" @bind:event="oninput" placeholder="Caută după nume sau oraș..."
                       class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red w-64" />
            </div>
            @{
                var filteredShops = string.IsNullOrWhiteSpace(_shopSearch)
                    ? _shops
                    : _shops.Where(s => s.Name.Contains(_shopSearch, StringComparison.OrdinalIgnoreCase) ||
                                        s.City.Contains(_shopSearch, StringComparison.OrdinalIgnoreCase)).ToList();
            }
            @if (filteredShops.Count == 0)
            {
                <div class="flex flex-col items-center justify-center py-16 text-text-muted gap-2">
                    <span class="material-symbols-outlined text-4xl">store</span>
                    <p class="text-sm">Niciun serviciu găsit.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-surface-container text-text-warm text-xs uppercase tracking-wide">
                            <tr>
                                <th class="px-5 py-3 text-left font-semibold">Serviciu</th>
                                <th class="px-5 py-3 text-left font-semibold">Categorie</th>
                                <th class="px-5 py-3 text-left font-semibold">Oraș</th>
                                <th class="px-5 py-3 text-left font-semibold">Status</th>
                                <th class="px-5 py-3 text-left font-semibold">Rating</th>
                                <th class="px-5 py-3 text-left font-semibold">Acțiuni</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-light">
                            @foreach (var shop in filteredShops)
                            {
                                <tr class="hover:bg-surface-container/50 transition-colors">
                                    <td class="px-5 py-4">
                                        <p class="font-semibold text-text-main">@shop.Name</p>
                                        @if (shop.Status == ShopStatus.Inactive && shop.DisabledReason is { Length: > 0 })
                                        {
                                            <p class="text-xs text-brand-red mt-0.5 max-w-[220px] truncate" title="@shop.DisabledReason">
                                                Motiv: @shop.DisabledReason
                                            </p>
                                        }
                                    </td>
                                    <td class="px-5 py-4 text-text-muted">@CategoryLabel(shop.Category)</td>
                                    <td class="px-5 py-4 text-text-muted">@shop.City</td>
                                    <td class="px-5 py-4">
                                        <span class="px-2.5 py-1 rounded-full text-xs font-bold @ShopStatusClass(shop.Status)">
                                            @ShopStatusLabel(shop.Status)
                                        </span>
                                    </td>
                                    <td class="px-5 py-4">
                                        <div class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-brand-red text-base" style="font-variation-settings: 'FILL' 1;">star</span>
                                            <span class="font-semibold text-text-main">@shop.AverageRating.ToString("0.0")</span>
                                            <span class="text-text-muted text-xs">(@shop.ReviewCount)</span>
                                        </div>
                                    </td>
                                    <td class="px-5 py-4">
                                        <div class="flex gap-2 flex-wrap">
                                            <button @onclick="() => OpenEditShop(shop)"
                                                    class="px-3 py-1.5 border border-border-light text-xs font-bold rounded text-text-muted hover:text-text-main hover:bg-surface-container transition-colors">
                                                Editează
                                            </button>
                                            @if (shop.Status == ShopStatus.Active)
                                            {
                                                <button @onclick="() => OpenDisableShop(shop)"
                                                        class="px-3 py-1.5 border border-red-200 text-xs font-bold rounded text-brand-red hover:bg-brand-red-faint transition-colors">
                                                    Dezactivează
                                                </button>
                                            }
                                            else
                                            {
                                                <button @onclick="async () => await EnableShop(shop)"
                                                        class="px-3 py-1.5 border border-green-200 text-xs font-bold rounded text-green-600 hover:bg-green-50 transition-colors">
                                                    Activează
                                                </button>
                                            }
                                            <a href="/serviciu/@shop.Id" target="_blank"
                                               class="px-3 py-1.5 border border-border-light text-xs font-bold rounded text-text-muted hover:text-text-main hover:bg-surface-container transition-colors">
                                                Vizualizează
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
    else if (_tab == "users")
    {
        <div class="bg-white rounded-xl border border-border-light overflow-hidden">
            <div class="px-6 py-4 border-b border-border-light flex items-center justify-between flex-wrap gap-3">
                <div class="flex items-center gap-3">
                    <h2 class="font-bold text-text-main" style="font-family: Manrope, sans-serif;">Utilizatori</h2>
                    <div class="flex rounded-lg border border-border-light overflow-hidden text-xs font-semibold">
                        <button @onclick='() => _showDisabledUsers = false'
                                class="px-3 py-1.5 transition-colors @(!_showDisabledUsers ? "bg-brand-red text-white" : "text-text-muted hover:bg-surface-low")">
                            Activi
                        </button>
                        <button @onclick='() => _showDisabledUsers = true'
                                class="px-3 py-1.5 transition-colors @(_showDisabledUsers ? "bg-brand-red text-white" : "text-text-muted hover:bg-surface-low")">
                            Dezactivați
                        </button>
                    </div>
                </div>
                <input @bind="_userSearch" @bind:event="oninput" placeholder="Caută după nume sau email..."
                       class="border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red w-64" />
            </div>
            @{
                var filteredUsers = _users
                    .Where(u => u.IsDisabled == _showDisabledUsers)
                    .Where(u => string.IsNullOrWhiteSpace(_userSearch) ||
                                (u.FullName ?? "").Contains(_userSearch, StringComparison.OrdinalIgnoreCase) ||
                                (u.Email ?? "").Contains(_userSearch, StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }
            @if (filteredUsers.Count == 0)
            {
                <div class="flex flex-col items-center justify-center py-16 text-text-muted gap-2">
                    <span class="material-symbols-outlined text-4xl">group</span>
                    <p class="text-sm">Niciun utilizator găsit.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-surface-container text-text-warm text-xs uppercase tracking-wide">
                            <tr>
                                <th class="px-5 py-3 text-left font-semibold">Utilizator</th>
                                <th class="px-5 py-3 text-left font-semibold">Email</th>
                                <th class="px-5 py-3 text-left font-semibold">Rol</th>
                                <th class="px-5 py-3 text-left font-semibold">Înregistrat</th>
                                <th class="px-5 py-3 text-left font-semibold">Acțiuni</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-light">
                            @foreach (var user in filteredUsers)
                            {
                                var role = _userRoles.GetValueOrDefault(user.Id, "User");
                                var isLocked = user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow && !user.IsDisabled;
                                var isSuperAdminUser = role == "SuperAdmin";
                                var isAdminUser = role == "Admin";
                                var canAct = isSuperAdminUser ? false : isAdminUser ? _isSuperAdmin : true;
                                <tr class="hover:bg-surface-container/50 transition-colors @(user.IsDisabled ? "opacity-60" : "")">
                                    <td class="px-5 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-brand-red-faint text-brand-red flex items-center justify-center text-xs font-bold shrink-0">
                                                @Initials(user.FullName is { Length: > 0 } fn ? fn : user.Email ?? "?")
                                            </div>
                                            <div>
                                                <span class="font-medium text-text-main">@(user.FullName is { Length: > 0 } n ? n : "–")</span>
                                                @if (user.IsDisabled)
                                                {
                                                    <span class="ml-2 text-[10px] font-bold bg-red-100 text-brand-red px-1.5 py-0.5 rounded">Dezactivat</span>
                                                }
                                                else if (isLocked)
                                                {
                                                    <span class="ml-2 text-[10px] font-bold bg-orange-100 text-orange-600 px-1.5 py-0.5 rounded">Blocat</span>
                                                }
                                                @if (user.IsDisabled && user.DisabledReason is { Length: > 0 })
                                                {
                                                    <p class="text-xs text-text-muted mt-0.5 max-w-[200px] truncate" title="@user.DisabledReason">@user.DisabledReason</p>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-5 py-4 text-text-muted">@user.Email</td>
                                    <td class="px-5 py-4">
                                        @if (isSuperAdminUser || !canAct)
                                        {
                                            <span class="px-2 py-1 rounded text-xs font-bold @RoleBadgeClass(role)">@role</span>
                                        }
                                        else
                                        {
                                            <select value="@role" @onchange="async e => await ChangeRole(user, e.Value?.ToString() ?? role)"
                                                    class="border border-border-light rounded px-2 py-1 text-xs font-semibold bg-white focus:outline-none focus:ring-1 focus:ring-brand-red @RoleBadgeClass(role)">
                                                <option value="User">User</option>
                                                <option value="ShopOwner">ShopOwner</option>
                                                @if (_isSuperAdmin)
                                                {
                                                    <option value="Admin">Admin</option>
                                                }
                                            </select>
                                        }
                                    </td>
                                    <td class="px-5 py-4 text-text-muted text-xs">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td class="px-5 py-4">
                                        @if (canAct)
                                        {
                                            <div class="flex gap-2 flex-wrap">
                                                @if (user.IsDisabled)
                                                {
                                                    <button @onclick="async () => await RestoreUser(user)"
                                                            class="px-3 py-1.5 border border-green-200 text-xs font-bold rounded text-green-600 hover:bg-green-50 transition-colors">
                                                        Restaurează
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button @onclick="() => OpenEditUser(user)"
                                                            class="px-3 py-1.5 border border-border-light text-xs font-bold rounded text-text-muted hover:text-text-main hover:bg-surface-container transition-colors">
                                                        Editează
                                                    </button>
                                                    <button @onclick="() => OpenResetPassword(user)"
                                                            class="px-3 py-1.5 border border-border-light text-xs font-bold rounded text-text-muted hover:text-text-main hover:bg-surface-container transition-colors">
                                                        Resetează parola
                                                    </button>
                                                    <button @onclick="async () => await ToggleLock(user)"
                                                            class="px-3 py-1.5 border text-xs font-bold rounded transition-colors @(isLocked ? "border-green-200 text-green-600 hover:bg-green-50" : "border-orange-200 text-orange-600 hover:bg-orange-50")">
                                                        @(isLocked ? "Deblochează" : "Blochează")
                                                    </button>
                                                    <button @onclick="() => OpenDisableUser(user)"
                                                            class="px-3 py-1.5 border border-red-200 text-xs font-bold rounded text-brand-red hover:bg-brand-red-faint transition-colors">
                                                        Dezactivează
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
    else
    {
        @if (!_reviewsLoaded)
        {
            <div class="flex items-center justify-center py-16 text-text-muted gap-2">
                <span class="material-symbols-outlined animate-spin">progress_activity</span>
                Se încarcă...
            </div>
        }
        else
        {
            <div class="bg-white rounded-xl border border-border-light overflow-hidden">
                <div class="px-6 py-4 border-b border-border-light flex items-center justify-between">
                    <h2 class="font-bold text-text-main" style="font-family: Manrope, sans-serif;">Toate recenziile</h2>
                    <span class="text-sm text-text-muted">@_reviewCount total</span>
                </div>
                @if (_adminReviews.Count == 0)
                {
                    <div class="flex flex-col items-center justify-center py-16 text-text-muted gap-2">
                        <span class="material-symbols-outlined text-4xl">rate_review</span>
                        <p class="text-sm">Nicio recenzie.</p>
                    </div>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="bg-surface-container text-text-warm text-xs uppercase tracking-wide">
                                <tr>
                                    <th class="px-5 py-3 text-left font-semibold">Utilizator</th>
                                    <th class="px-5 py-3 text-left font-semibold">Serviciu</th>
                                    <th class="px-5 py-3 text-left font-semibold">Rating</th>
                                    <th class="px-5 py-3 text-left font-semibold">Recenzie</th>
                                    <th class="px-5 py-3 text-left font-semibold">Data</th>
                                    <th class="px-5 py-3 text-left font-semibold">Acțiuni</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-border-light">
                                @foreach (var rev in _adminReviews)
                                {
                                    <tr class="hover:bg-surface-container/50 transition-colors">
                                        <td class="px-5 py-4 font-medium text-text-main">@rev.UserName</td>
                                        <td class="px-5 py-4 text-text-muted">@rev.Shop?.Name</td>
                                        <td class="px-5 py-4">
                                            <div class="flex gap-0.5">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <span class="material-symbols-outlined text-sm @(i <= rev.Rating ? "text-brand-red" : "text-gray-300")"
                                                          style="font-variation-settings: 'FILL' 1;">star</span>
                                                }
                                            </div>
                                        </td>
                                        <td class="px-5 py-4 text-text-muted max-w-xs truncate">@rev.Text</td>
                                        <td class="px-5 py-4 text-text-muted text-xs">@rev.CreatedAt.ToString("dd MMM yyyy")</td>
                                        <td class="px-5 py-4">
                                            <button @onclick="async () => await DeleteReview(rev)"
                                                    class="px-3 py-1.5 border border-red-200 text-brand-red hover:bg-brand-red-faint text-xs font-bold rounded transition-colors">
                                                Șterge
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (_reviewCount > _adminReviews.Count)
                    {
                        <div class="px-6 py-4 border-t border-border-light">
                            <button @onclick="LoadMoreAdminReviews"
                                    class="text-sm font-semibold text-brand-red hover:underline">
                                Încarcă mai multe (@(_reviewCount - _adminReviews.Count) rămase)
                            </button>
                        </div>
                    }
                }
            </div>
        }
    }

</div>

<!-- ── Edit Shop Modal ── -->
@if (_editingShop is not null)
{
    <div class="fixed inset-0 z-50 bg-black/60 flex items-center justify-center p-4" @onclick="() => _editingShop = null">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl p-8 max-h-[90vh] overflow-y-auto" @onclick:stopPropagation="true">
            <h3 class="font-bold text-xl text-text-main mb-6" style="font-family: Manrope, sans-serif;">Editează serviciu</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="sm:col-span-2">
                    <label class="block text-xs font-semibold text-text-muted mb-1">Nume</label>
                    <input @bind="_esName" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red" />
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-xs font-semibold text-text-muted mb-1">Descriere</label>
                    <textarea @bind="_esDescription" rows="3" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red resize-none"></textarea>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-xs font-semibold text-text-muted mb-1">Adresă</label>
                    <input @bind="_esAddress" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-text-muted mb-1">Oraș</label>
                    <input @bind="_esCity" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-text-muted mb-1">Județ</label>
                    <input @bind="_esCounty" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-text-muted mb-1">Telefon</label>
                    <input @bind="_esPhone" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-text-muted mb-1">Email</label>
                    <input @bind="_esEmail" type="email" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red" />
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-xs font-semibold text-text-muted mb-1">Website</label>
                    <input @bind="_esWebsite" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red" />
                </div>
            </div>
            @if (_esError is { Length: > 0 })
            {
                <p class="text-sm text-brand-red mt-4">@_esError</p>
            }
            <div class="flex gap-3 mt-6">
                <button @onclick="() => _editingShop = null"
                        class="flex-1 py-3 border border-border-light text-text-muted font-semibold rounded-lg hover:bg-surface-low transition-colors text-sm">
                    Anulează
                </button>
                <button @onclick="SaveShop" disabled="@_esSaving"
                        class="flex-1 py-3 bg-brand-red text-white font-bold rounded-lg hover:bg-brand-red-dark disabled:opacity-50 transition-all text-sm">
                    @(_esSaving ? "Se salvează..." : "Salvează")
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Edit User Modal ── -->
@if (_editingUser is not null)
{
    <div class="fixed inset-0 z-50 bg-black/60 flex items-center justify-center p-4" @onclick="() => _editingUser = null">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8" @onclick:stopPropagation="true">
            <h3 class="font-bold text-xl text-text-main mb-6" style="font-family: Manrope, sans-serif;">Editează utilizator</h3>
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-text-muted mb-1">Nume complet</label>
                    <input @bind="_euFullName" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-text-muted mb-1">Email</label>
                    <input @bind="_euEmail" type="email" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red" />
                </div>
            </div>
            @if (_euError is { Length: > 0 })
            {
                <p class="text-sm text-brand-red mt-3">@_euError</p>
            }
            <div class="flex gap-3 mt-6">
                <button @onclick="() => _editingUser = null"
                        class="flex-1 py-3 border border-border-light text-text-muted font-semibold rounded-lg hover:bg-surface-low transition-colors text-sm">
                    Anulează
                </button>
                <button @onclick="SaveUser" disabled="@_euSaving"
                        class="flex-1 py-3 bg-brand-red text-white font-bold rounded-lg hover:bg-brand-red-dark disabled:opacity-50 transition-all text-sm">
                    @(_euSaving ? "Se salvează..." : "Salvează")
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Disable User Modal ── -->
@if (_disablingUser is not null)
{
    <div class="fixed inset-0 z-50 bg-black/60 flex items-center justify-center p-4" @onclick="() => _disablingUser = null">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8" @onclick:stopPropagation="true">
            <div class="flex items-center gap-3 mb-2">
                <span class="material-symbols-outlined text-brand-red">person_off</span>
                <h3 class="font-bold text-xl text-text-main" style="font-family: Manrope, sans-serif;">Dezactivează cont</h3>
            </div>
            <p class="text-sm text-text-muted mb-4">
                Contul lui <strong>@(_disablingUser.FullName is { Length: > 0 } n ? n : _disablingUser.Email)</strong> va fi dezactivat și nu va mai putea accesa platforma.
            </p>
            <label class="block text-xs font-semibold text-text-muted mb-1">Motiv (obligatoriu)</label>
            <textarea @bind="_disableUserReason" rows="3" placeholder="Descrie motivul dezactivării..."
                      class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red resize-none mb-4"></textarea>
            <div class="flex gap-3">
                <button @onclick="() => _disablingUser = null"
                        class="flex-1 py-3 border border-border-light text-text-muted font-semibold rounded-lg hover:bg-surface-low transition-colors text-sm">
                    Anulează
                </button>
                <button @onclick="ConfirmDisableUser" disabled="@(string.IsNullOrWhiteSpace(_disableUserReason))"
                        class="flex-1 py-3 bg-brand-red text-white font-bold rounded-lg hover:bg-brand-red-dark disabled:opacity-50 transition-all text-sm">
                    Dezactivează
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Disable Shop Modal ── -->
@if (_disablingShop is not null)
{
    <div class="fixed inset-0 z-50 bg-black/60 flex items-center justify-center p-4" @onclick="() => _disablingShop = null">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8" @onclick:stopPropagation="true">
            <div class="flex items-center gap-3 mb-2">
                <span class="material-symbols-outlined text-brand-red">store_off</span>
                <h3 class="font-bold text-xl text-text-main" style="font-family: Manrope, sans-serif;">Dezactivează serviciu</h3>
            </div>
            <p class="text-sm text-text-muted mb-4">
                Serviciul <strong>@_disablingShop.Name</strong> va fi ascuns din rezultatele publice iar proprietarul va vedea motivul dezactivării.
            </p>
            <label class="block text-xs font-semibold text-text-muted mb-1">Motiv (obligatoriu)</label>
            <textarea @bind="_disableShopReason" rows="3" placeholder="Descrie motivul dezactivării..."
                      class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-brand-red resize-none mb-4"></textarea>
            <div class="flex gap-3">
                <button @onclick="() => _disablingShop = null"
                        class="flex-1 py-3 border border-border-light text-text-muted font-semibold rounded-lg hover:bg-surface-low transition-colors text-sm">
                    Anulează
                </button>
                <button @onclick="ConfirmDisableShop" disabled="@(string.IsNullOrWhiteSpace(_disableShopReason))"
                        class="flex-1 py-3 bg-brand-red text-white font-bold rounded-lg hover:bg-brand-red-dark disabled:opacity-50 transition-all text-sm">
                    Dezactivează
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Reset Password Modal ── -->
@if (_resetPwUser is not null)
{
    <div class="fixed inset-0 z-50 bg-black/60 flex items-center justify-center p-4" @onclick="() => _resetPwUser = null">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8" @onclick:stopPropagation="true">
            <div class="flex items-center gap-3 mb-2">
                <span class="material-symbols-outlined text-brand-red">lock_reset</span>
                <h3 class="font-bold text-xl text-text-main" style="font-family: Manrope, sans-serif;">Resetare parolă</h3>
            </div>
            <p class="text-sm text-text-muted mb-4">
                Link de resetare pentru <strong>@(_resetPwUser.FullName is { Length: > 0 } n ? n : _resetPwUser.Email)</strong>. Trimite-l utilizatorului — este valabil o singură dată.
            </p>
            <div class="flex gap-2 mb-4">
                <input value="@_resetPwUrl" readonly
                       class="flex-1 border border-border-light rounded-lg px-3 py-2 text-xs text-text-muted bg-surface-container focus:outline-none" />
                <button @onclick='async () => await JS.InvokeVoidAsync("copyToClipboard", _resetPwUrl)'
                        class="px-4 py-2 bg-brand-red text-white text-xs font-bold rounded-lg hover:bg-brand-red-dark transition-colors shrink-0">
                    Copiază
                </button>
            </div>
            <button @onclick="() => _resetPwUser = null"
                    class="w-full py-3 border border-border-light text-text-muted font-semibold rounded-lg hover:bg-surface-low transition-colors text-sm">
                Închide
            </button>
        </div>
    </div>
}

@code {
    private string _tab = "requests";
    private bool _isSuperAdmin;
    private string _currentAdminId = string.Empty;

    private List<ShopRequest> _requests = [];
    private List<Shop> _shops = [];
    private List<ApplicationUser> _users = [];
    private Dictionary<string, string> _userRoles = [];
    private int _activeShops;
    private int _pendingCount;
    private int _userCount;
    private int _reviewCount;
    private int? _rejectingId;
    private string _rejectNote = "";

    private string _shopSearch = "";
    private string _userSearch = "";
    private bool _showDisabledUsers;

    private List<Review> _adminReviews = [];
    private bool _reviewsLoaded;
    private int _adminReviewPage = 1;
    private const int AdminReviewPageSize = 20;

    // Edit shop state
    private Shop? _editingShop;
    private string _esName = "", _esDescription = "", _esAddress = "", _esCity = "",
                   _esCounty = "", _esPhone = "", _esEmail = "", _esWebsite = "";
    private bool _esSaving;
    private string _esError = "";

    // Edit user state
    private ApplicationUser? _editingUser;
    private string _euFullName = "", _euEmail = "";
    private bool _euSaving;
    private string _euError = "";

    // Disable modals
    private ApplicationUser? _disablingUser;
    private string _disableUserReason = "";
    private Shop? _disablingShop;
    private string _disableShopReason = "";

    // Reset password
    private ApplicationUser? _resetPwUser;
    private string _resetPwUrl = "";

    private (string id, string label)[] Tabs => [
        ("requests", $"Cereri ({_pendingCount})"),
        ("shops", "Servicii"),
        ("users", "Utilizatori"),
        ("reviews", "Recenzii"),
    ];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!state.User.IsInRole("Admin") && !state.User.IsInRole("SuperAdmin"))
        {
            Nav.NavigateTo("/auth/login", forceLoad: true);
            return;
        }
        _isSuperAdmin = state.User.IsInRole("SuperAdmin");
        _currentAdminId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        await LoadData();
    }

    private async Task LoadData()
    {
        _requests = await RequestRepo.GetAllAsync();
        _shops    = await ShopRepo.GetAllAsync();
        _users    = await UserMgr.Users.ToListAsync();
        _reviewCount = await ReviewRepo.GetTotalCountAsync();
        _activeShops = _shops.Count(s => s.Status == ShopStatus.Active);
        _pendingCount = _requests.Count(r => r.Status == ShopRequestStatus.Pending);
        _userCount = _users.Count(u => !u.IsDisabled);

        foreach (var user in _users)
        {
            var roles = await UserMgr.GetRolesAsync(user);
            _userRoles[user.Id] = roles.FirstOrDefault() ?? "User";
        }
    }

    private async Task SwitchTab(string tab)
    {
        _tab = tab;
        if (tab == "reviews" && !_reviewsLoaded)
        {
            var (items, _) = await ReviewRepo.GetAllAsync(1, AdminReviewPageSize);
            _adminReviews  = items;
            _reviewsLoaded = true;
        }
    }

    private async Task LoadMoreAdminReviews()
    {
        _adminReviewPage++;
        var (items, _) = await ReviewRepo.GetAllAsync(_adminReviewPage, AdminReviewPageSize);
        _adminReviews.AddRange(items);
    }

    private async Task DeleteReview(Review rev)
    {
        await ReviewRepo.DeleteAsync(rev.Id);
        await ShopRepo.RecalcRatingAsync(rev.ShopId);
        _adminReviews.Remove(rev);
        _reviewCount--;
    }

    // ── Toggle lock (temporary, no reason) ─────────────────────────────────
    private async Task ToggleLock(ApplicationUser user)
    {
        await UserMgr.SetLockoutEnabledAsync(user, true);
        var isLocked = user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow;
        if (isLocked)
        {
            await UserMgr.SetLockoutEndDateAsync(user, null);
            user.LockoutEnd = null;
        }
        else
        {
            await UserMgr.SetLockoutEndDateAsync(user, DateTimeOffset.MaxValue);
            user.LockoutEnd = DateTimeOffset.MaxValue;
        }
    }

    // ── Soft-disable user ───────────────────────────────────────────────────
    private void OpenDisableUser(ApplicationUser user) { _disablingUser = user; _disableUserReason = ""; }

    private async Task ConfirmDisableUser()
    {
        if (_disablingUser is null || string.IsNullOrWhiteSpace(_disableUserReason)) return;
        _disablingUser.IsDisabled        = true;
        _disablingUser.DisabledReason    = _disableUserReason.Trim();
        _disablingUser.DisabledAt        = DateTime.UtcNow;
        _disablingUser.DisabledByAdminId = _currentAdminId;
        await UserMgr.UpdateAsync(_disablingUser);
        await UserMgr.SetLockoutEnabledAsync(_disablingUser, true);
        await UserMgr.SetLockoutEndDateAsync(_disablingUser, DateTimeOffset.MaxValue);
        _disablingUser.LockoutEnd = DateTimeOffset.MaxValue;
        _disablingUser     = null;
        _disableUserReason = "";
        _userCount = _users.Count(u => !u.IsDisabled);
    }

    private async Task RestoreUser(ApplicationUser user)
    {
        user.IsDisabled        = false;
        user.DisabledReason    = null;
        user.DisabledAt        = null;
        user.DisabledByAdminId = null;
        await UserMgr.UpdateAsync(user);
        await UserMgr.SetLockoutEndDateAsync(user, null);
        user.LockoutEnd = null;
        _userCount = _users.Count(u => !u.IsDisabled);
    }

    // ── Soft-disable shop ───────────────────────────────────────────────────
    private void OpenDisableShop(Shop shop) { _disablingShop = shop; _disableShopReason = ""; }

    private async Task ConfirmDisableShop()
    {
        if (_disablingShop is null || string.IsNullOrWhiteSpace(_disableShopReason)) return;
        await ShopRepo.SetStatusAsync(_disablingShop.Id, ShopStatus.Inactive, _disableShopReason.Trim());
        _disablingShop.Status         = ShopStatus.Inactive;
        _disablingShop.DisabledReason = _disableShopReason.Trim();
        _disablingShop     = null;
        _disableShopReason = "";
        _activeShops = _shops.Count(s => s.Status == ShopStatus.Active);
    }

    private async Task EnableShop(Shop shop)
    {
        await ShopRepo.SetStatusAsync(shop.Id, ShopStatus.Active);
        shop.Status         = ShopStatus.Active;
        shop.DisabledReason = null;
        _activeShops = _shops.Count(s => s.Status == ShopStatus.Active);
    }

    // ── Edit shop ───────────────────────────────────────────────────────────
    private void OpenEditShop(Shop shop)
    {
        _editingShop    = shop;
        _esName         = shop.Name;
        _esDescription  = shop.Description;
        _esAddress      = shop.Address;
        _esCity         = shop.City;
        _esCounty       = shop.County;
        _esPhone        = shop.Phone;
        _esEmail        = shop.Email;
        _esWebsite      = shop.Website ?? "";
        _esError        = "";
    }

    private async Task SaveShop()
    {
        if (_editingShop is null) return;
        _esSaving = true;
        _esError  = "";
        try
        {
            await ShopRepo.UpdateProfileAsync(_editingShop.Id, _esName, _esDescription, _esAddress,
                _esCity, _esCounty, _esPhone, _esEmail,
                string.IsNullOrWhiteSpace(_esWebsite) ? null : _esWebsite,
                _editingShop.Sector);
            _editingShop.Name        = _esName;
            _editingShop.Description = _esDescription;
            _editingShop.Address     = _esAddress;
            _editingShop.City        = _esCity;
            _editingShop.County      = _esCounty;
            _editingShop.Phone       = _esPhone;
            _editingShop.Email       = _esEmail;
            _editingShop.Website     = string.IsNullOrWhiteSpace(_esWebsite) ? null : _esWebsite;
            _editingShop = null;
        }
        catch { _esError = "A apărut o eroare. Încearcă din nou."; }
        finally { _esSaving = false; }
    }

    // ── Edit user ───────────────────────────────────────────────────────────
    private void OpenEditUser(ApplicationUser user)
    {
        _editingUser = user;
        _euFullName  = user.FullName ?? "";
        _euEmail     = user.Email   ?? "";
        _euError     = "";
    }

    private async Task SaveUser()
    {
        if (_editingUser is null) return;
        _euSaving = true;
        _euError  = "";
        try
        {
            _editingUser.FullName = _euFullName.Trim();
            var trimmedEmail = _euEmail.Trim();
            if (_editingUser.Email != trimmedEmail)
            {
                var token  = await UserMgr.GenerateChangeEmailTokenAsync(_editingUser, trimmedEmail);
                var result = await UserMgr.ChangeEmailAsync(_editingUser, trimmedEmail, token);
                if (!result.Succeeded)
                {
                    _euError = result.Errors.FirstOrDefault()?.Description ?? "Eroare la schimbarea emailului.";
                    return;
                }
                await UserMgr.SetUserNameAsync(_editingUser, trimmedEmail);
            }
            else
            {
                await UserMgr.UpdateAsync(_editingUser);
            }
            _editingUser = null;
        }
        catch { _euError = "A apărut o eroare. Încearcă din nou."; }
        finally { _euSaving = false; }
    }

    // ── Reset password ──────────────────────────────────────────────────────
    private async Task OpenResetPassword(ApplicationUser user)
    {
        _resetPwUser = user;
        var token    = await UserMgr.GeneratePasswordResetTokenAsync(user);
        var baseUri  = Nav.BaseUri.TrimEnd('/');
        _resetPwUrl  = $"{baseUri}/auth/set-password?userId={Uri.EscapeDataString(user.Id)}&token={Uri.EscapeDataString(token)}";
    }

    // ── Change role ─────────────────────────────────────────────────────────
    private async Task ChangeRole(ApplicationUser user, string newRole)
    {
        var current = _userRoles.GetValueOrDefault(user.Id, "User");
        if (current == newRole) return;
        if ((current == "Admin" || newRole == "Admin") && !_isSuperAdmin) return;
        await UserMgr.RemoveFromRoleAsync(user, current);
        await UserMgr.AddToRoleAsync(user, newRole);
        _userRoles[user.Id] = newRole;
    }

    // ── Request actions ─────────────────────────────────────────────────────
    private async Task ApproveRequest(int id)
    {
        var req = _requests.First(r => r.Id == id);

        var owner = await UserMgr.FindByEmailAsync(req.Email);
        if (owner is null)
        {
            owner = new ApplicationUser
            {
                UserName       = req.Email,
                Email          = req.Email,
                FullName       = req.ContactPerson,
                EmailConfirmed = true,
                CreatedAt      = DateTime.UtcNow
            };
            var createResult = await UserMgr.CreateAsync(owner);
            if (!createResult.Succeeded) return;
            await UserMgr.AddToRoleAsync(owner, "ShopOwner");
        }
        else if (!await UserMgr.IsInRoleAsync(owner, "ShopOwner"))
        {
            await UserMgr.AddToRoleAsync(owner, "ShopOwner");
        }

        var shop = new Shop
        {
            Name        = req.ShopName,
            Description = req.Description ?? string.Empty,
            Address     = string.Empty,
            City        = req.City,
            County      = req.County,
            Phone       = req.Phone,
            Email       = req.Email,
            Category    = req.Category,
            Status      = ShopStatus.Active,
            OwnerId     = owner.Id
        };
        await ShopRepo.CreateAsync(shop);
        _shops.Add(shop);

        var token      = await UserMgr.GeneratePasswordResetTokenAsync(owner);
        var baseUri    = Nav.BaseUri.TrimEnd('/');
        var setupUrl   = $"{baseUri}/auth/set-password?userId={Uri.EscapeDataString(owner.Id)}&token={Uri.EscapeDataString(token)}";

        var html = $"""
            <p>Bună, {req.ContactPerson}!</p>
            <p>Cererea ta pentru <strong>{req.ShopName}</strong> a fost aprobată pe PitStop.</p>
            <p style="margin:24px 0;">
              <a href="{setupUrl}" style="background:#C0392B;color:#fff;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:bold;">
                Configurează contul
              </a>
            </p>
            """;

        try { await EmailSvc.SendAsync(req.Email, "Contul tău PitStop a fost aprobat", html); }
        catch { /* email failure should not block approval */ }

        req.Status = ShopRequestStatus.Approved;
        await RequestRepo.UpdateAsync(req);
        _pendingCount = _requests.Count(r => r.Status == ShopRequestStatus.Pending);
        _activeShops  = _shops.Count(s => s.Status == ShopStatus.Active);
    }

    private async Task RejectRequest(int id)
    {
        var req = _requests.First(r => r.Id == id);
        req.Status    = ShopRequestStatus.Rejected;
        req.AdminNote = _rejectNote;
        await RequestRepo.UpdateAsync(req);
        _rejectingId  = null;
        _rejectNote   = "";
        _pendingCount = _requests.Count(r => r.Status == ShopRequestStatus.Pending);
    }

    // ── Helpers ─────────────────────────────────────────────────────────────
    private static string RequestStatusClass(ShopRequestStatus s) => s switch
    {
        ShopRequestStatus.Pending  => "bg-orange-100 text-orange-600",
        ShopRequestStatus.Approved => "bg-green-100 text-green-700",
        ShopRequestStatus.Rejected => "bg-red-100 text-brand-red",
        _ => "bg-surface-container text-text-muted"
    };

    private static string RequestStatusLabel(ShopRequestStatus s) => s switch
    {
        ShopRequestStatus.Pending  => "În așteptare",
        ShopRequestStatus.Approved => "Aprobat",
        ShopRequestStatus.Rejected => "Respins",
        _ => s.ToString()
    };

    private static string ShopStatusClass(ShopStatus s) => s switch
    {
        ShopStatus.Active   => "bg-green-100 text-green-700",
        ShopStatus.Pending  => "bg-orange-100 text-orange-600",
        ShopStatus.Inactive => "bg-surface-container text-text-muted",
        ShopStatus.Rejected => "bg-red-100 text-brand-red",
        _ => "bg-surface-container text-text-muted"
    };

    private static string ShopStatusLabel(ShopStatus s) => s switch
    {
        ShopStatus.Active   => "Activ",
        ShopStatus.Pending  => "În așteptare",
        ShopStatus.Inactive => "Inactiv",
        ShopStatus.Rejected => "Respins",
        _ => s.ToString()
    };

    private static string RoleBadgeClass(string role) => role switch
    {
        "SuperAdmin" => "bg-brand-red-faint text-brand-red",
        "Admin"      => "bg-brand-red-faint text-brand-red",
        "ShopOwner"  => "bg-secondary-light text-secondary",
        _            => "bg-surface-container text-text-muted"
    };

    private static string CategoryLabel(ShopCategory cat) => cat switch
    {
        ShopCategory.ServiceAuto => "Service Auto",
        ShopCategory.PieseAuto   => "Piese Auto",
        ShopCategory.Spalatorie  => "Spălătorie",
        ShopCategory.Vopsitorie  => "Vopsitorie",
        ShopCategory.Vulcanizare => "Vulcanizare",
        ShopCategory.Tuning      => "Tuning",
        ShopCategory.Tractari    => "Tractări",
        ShopCategory.Detailing   => "Detailing",
        ShopCategory.ITP         => "ITP",
        ShopCategory.ServiceMoto => "Service Moto",
        ShopCategory.PieseMoto   => "Piese Moto",
        ShopCategory.Altele      => "Altele",
        _ => cat.ToString()
    };
}
