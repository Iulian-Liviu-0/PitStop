@page "/auth/set-password"
@rendermode InteractiveServer

<PageTitle>Configurare cont - PitStop</PageTitle>

<div class="min-h-screen bg-surface flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-[440px] bg-white rounded-xl shadow-md overflow-hidden p-8">

        <div class="text-center mb-8">
            <h1 class="text-3xl font-black italic tracking-tighter text-brand-red"
                style="font-family: Manrope, sans-serif;">PitStop</h1>
            <p class="text-text-muted text-sm mt-2">Configurează parola contului tău de proprietar.</p>
        </div>

        @if (_invalidLink)
        {
            <div class="flex flex-col items-center gap-4 text-center py-4">
                <span class="material-symbols-outlined text-5xl text-brand-red">link_off</span>
                <p class="font-bold text-text-main">Link invalid sau expirat</p>
                <p class="text-sm text-text-muted">Contactează echipa PitStop pentru a primi un nou link de configurare.</p>
                <a href="/contact" class="mt-2 bg-brand-red text-white font-bold px-6 py-3 rounded-lg text-sm hover:bg-brand-red-dark transition-colors">
                    Contactează-ne
                </a>
            </div>
        }
        else
        {
            <form method="post" action="/auth/do-set-password" class="space-y-5">
                <AntiforgeryToken />
                <input type="hidden" name="userId" value="@UserId" />
                <input type="hidden" name="token" value="@Token" />

                <div class="space-y-1.5">
                    <label class="text-xs font-bold uppercase tracking-wider text-text-muted px-1">Parolă nouă</label>
                    <input name="password" type="password" placeholder="Minim 8 caractere, o cifră"
                           class="w-full px-4 py-3 bg-surface-bright rounded-lg border border-border-light focus:ring-2 focus:ring-brand-red/30 focus:border-brand-red text-sm outline-none transition-all" />
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold uppercase tracking-wider text-text-muted px-1">Confirmă parola</label>
                    <input name="confirmPassword" type="password" placeholder="••••••••"
                           class="w-full px-4 py-3 bg-surface-bright rounded-lg border border-border-light focus:ring-2 focus:ring-brand-red/30 focus:border-brand-red text-sm outline-none transition-all" />
                </div>

                @if (SetError is not null)
                {
                    <div class="px-4 py-3 bg-brand-red-faint border border-brand-red/20 rounded-lg text-sm text-brand-red font-medium">
                        @SetError
                    </div>
                }

                <button type="submit"
                        class="w-full py-3.5 bg-brand-red hover:bg-brand-red-dark text-white font-bold rounded-lg transition-all active:scale-[0.98]"
                        style="font-family: Manrope, sans-serif;">
                    Salvează parola și intră în cont
                </button>
            </form>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? UserId { get; set; }
    [SupplyParameterFromQuery] private string? Token { get; set; }
    [SupplyParameterFromQuery] private string? Err { get; set; }

    private bool _invalidLink;

    private string? SetError => Err switch
    {
        "mismatch" => "Parolele nu se potrivesc.",
        "weak"     => "Parola trebuie să aibă minim 8 caractere și o cifră.",
        "invalid"  => "Link-ul de configurare este invalid sau a expirat.",
        _          => null
    };

    protected override void OnParametersSet()
    {
        _invalidLink = string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token);
    }
}
