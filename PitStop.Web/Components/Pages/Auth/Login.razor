@page "/auth/login"
@rendermode InteractiveServer
@inject NavigationManager Nav

<PageTitle>Autentificare - PitStop</PageTitle>

<div class="min-h-screen bg-surface flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-[440px] bg-white rounded-xl shadow-md overflow-hidden">

        <!-- Tabs -->
        <div class="flex border-b border-border-light">
            <button @onclick='() => SetTab("login")'
                    class="flex-1 py-4 text-sm font-bold transition-all @(ActiveTab == "login" ? "text-brand-red border-b-2 border-brand-red" : "text-text-muted hover:text-brand-red")">
                Autentificare
            </button>
            <button @onclick='() => SetTab("register")'
                    class="flex-1 py-4 text-sm font-bold transition-all @(ActiveTab == "register" ? "text-brand-red border-b-2 border-brand-red" : "text-text-muted hover:text-brand-red")">
                Înregistrare
            </button>
        </div>

        <div class="p-8">

            <!-- Logo -->
            <div class="text-center mb-8">
                <h1 class="text-3xl font-black italic tracking-tighter text-brand-red"
                    style="font-family: Manrope, sans-serif;">PitStop</h1>
                <p class="text-text-muted text-sm mt-2">
                    @(ActiveTab == "login" ? "Bine ai revenit în comunitatea noastră." : "Creează-ți contul de utilizator.")
                </p>
            </div>

            <!-- ─── TAB LOGIN ─── -->
            @if (ActiveTab == "login")
            {
                <form method="post" action="/auth/do-login" class="space-y-5">
                    <AntiforgeryToken />
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wider text-text-muted px-1">Email</label>
                        <input name="email" type="email"
                               placeholder="nume@exemplu.ro"
                               class="w-full px-4 py-3 bg-surface-bright rounded-lg border border-border-light focus:ring-2 focus:ring-brand-red/30 focus:border-brand-red text-sm outline-none transition-all" />
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wider text-text-muted px-1">Parolă</label>
                        <div class="relative">
                            <input name="password"
                                   type="@(ShowPassword ? "text" : "password")"
                                   placeholder="••••••••"
                                   class="w-full px-4 py-3 bg-surface-bright rounded-lg border border-border-light focus:ring-2 focus:ring-brand-red/30 focus:border-brand-red text-sm outline-none transition-all pr-12" />
                            <button @onclick="() => ShowPassword = !ShowPassword" type="button"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-text-muted hover:text-brand-red transition-colors">
                                <span class="material-symbols-outlined text-xl">
                                    @(ShowPassword ? "visibility_off" : "visibility")
                                </span>
                            </button>
                        </div>
                    </div>

                    <div class="flex items-center justify-between text-xs font-medium">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input name="rememberMe" type="checkbox" value="true"
                                   class="w-4 h-4 rounded border-gray-300 text-brand-red focus:ring-brand-red" />
                            <span class="text-text-muted">Ține-mă minte</span>
                        </label>
                        <a href="#" class="text-brand-red font-bold hover:underline underline-offset-4">
                            Ai uitat parola?
                        </a>
                    </div>

                    @if (LoginError is not null)
                    {
                        <div class="px-4 py-3 bg-brand-red-faint border border-brand-red/20 rounded-lg text-sm text-brand-red font-medium">
                            @LoginError
                        </div>
                    }

                    <button type="submit"
                            class="w-full py-3.5 bg-brand-red hover:bg-brand-red-dark text-white font-bold rounded-lg transition-all active:scale-[0.98]"
                            style="font-family: Manrope, sans-serif;">
                        Autentifică-te
                    </button>

                    <!-- Divider -->
                    <div class="relative my-2 text-center">
                        <div class="absolute inset-0 flex items-center">
                            <span class="w-full border-t border-border-light"></span>
                        </div>
                        <span class="relative px-4 text-[10px] uppercase tracking-widest font-bold text-text-muted bg-white">
                            sau continuă cu
                        </span>
                    </div>

                    <button type="button"
                            class="w-full py-3 px-4 flex items-center justify-center gap-3 bg-white border border-border-light rounded-lg font-semibold text-sm text-text-main hover:bg-surface-bright transition-all active:scale-[0.98]">
                        <svg class="w-5 h-5" viewBox="0 0 24 24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        Continuă cu Google
                    </button>
                </form>
            }

            <!-- ─── TAB ÎNREGISTRARE ─── -->
            @if (ActiveTab == "register")
            {
                <form method="post" action="/auth/do-register" class="space-y-5">
                    <AntiforgeryToken />
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wider text-text-muted px-1">Nume complet</label>
                        <input name="name" type="text"
                               placeholder="Ion Popescu"
                               class="w-full px-4 py-3 bg-surface-bright rounded-lg border border-border-light focus:ring-2 focus:ring-brand-red/30 focus:border-brand-red text-sm outline-none transition-all" />
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wider text-text-muted px-1">Email</label>
                        <input name="email" type="email"
                               placeholder="nume@exemplu.ro"
                               class="w-full px-4 py-3 bg-surface-bright rounded-lg border border-border-light focus:ring-2 focus:ring-brand-red/30 focus:border-brand-red text-sm outline-none transition-all" />
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wider text-text-muted px-1">Parolă</label>
                        <input name="password" type="password"
                               placeholder="••••••••"
                               class="w-full px-4 py-3 bg-surface-bright rounded-lg border border-border-light focus:ring-2 focus:ring-brand-red/30 focus:border-brand-red text-sm outline-none transition-all" />
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wider text-text-muted px-1">Confirmă parola</label>
                        <input name="confirmPassword" type="password"
                               placeholder="••••••••"
                               class="w-full px-4 py-3 bg-surface-bright rounded-lg border border-border-light focus:ring-2 focus:ring-brand-red/30 focus:border-brand-red text-sm outline-none transition-all" />
                    </div>

                    <label class="flex items-start gap-3 cursor-pointer">
                        <input name="agreeTerms" type="checkbox" value="true"
                               class="w-4 h-4 mt-0.5 rounded border-gray-300 text-brand-red focus:ring-brand-red shrink-0" />
                        <span class="text-sm text-text-muted">
                            Sunt de acord cu
                            <a href="#" class="text-brand-red font-bold hover:underline">Termenii și Condițiile</a>
                            și
                            <a href="#" class="text-brand-red font-bold hover:underline">Politica de Confidențialitate</a>
                        </span>
                    </label>

                    @if (RegisterError is not null)
                    {
                        <div class="px-4 py-3 bg-brand-red-faint border border-brand-red/20 rounded-lg text-sm text-brand-red font-medium">
                            @RegisterError
                        </div>
                    }

                    <button type="submit"
                            class="w-full py-3.5 bg-brand-red hover:bg-brand-red-dark text-white font-bold rounded-lg transition-all active:scale-[0.98]"
                            style="font-family: Manrope, sans-serif;">
                        Creează cont
                    </button>

                    <p class="text-center text-sm text-text-muted">
                        Ai deja un cont?
                        <button @onclick='() => SetTab("login")' type="button"
                                class="text-brand-red font-bold hover:underline">
                            Autentifică-te
                        </button>
                    </p>

                    <!-- Banner proprietari service -->
                    <div class="mt-4 p-4 bg-brand-navy rounded-xl">
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-brand-red shrink-0 mt-0.5">store</span>
                            <div>
                                <p class="text-white text-sm font-bold mb-1" style="font-family: Manrope, sans-serif;">
                                    Ești proprietarul unui service?
                                </p>
                                <p class="text-white/60 text-xs leading-relaxed mb-3">
                                    Conturile pentru service-uri nu se creează direct.
                                    Trimite o cerere echipei PitStop și te vom contacta
                                    în maxim 24 de ore.
                                </p>
                                <a href="/contact"
                                   class="inline-flex items-center gap-1 text-xs font-bold text-brand-red hover:underline">
                                    Trimite o cerere
                                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            }

        </div>
    </div>
</div>

@code {
    private string ActiveTab = "login";
    private bool ShowPassword;

    [SupplyParameterFromQuery] private string? Tab { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }
    [SupplyParameterFromQuery] private string? RegError { get; set; }

    private string? LoginError => Error switch
    {
        "invalid" => "Email sau parolă incorecte.",
        "empty" => "Completează emailul și parola.",
        _ => null
    };

    private string? RegisterError => RegError switch
    {
        "mismatch" => "Parolele nu se potrivesc.",
        "terms" => "Trebuie să accepți termenii și condițiile.",
        "empty" => "Completează toate câmpurile.",
        "exists" => "Există deja un cont cu acest email.",
        "weak" => "Parola trebuie să aibă minim 8 caractere și o cifră.",
        _ => null
    };

    protected override void OnParametersSet()
    {
        ActiveTab = Tab == "register" || RegError is not null ? "register" : "login";
    }

    private void SetTab(string tab) => ActiveTab = tab;
}
