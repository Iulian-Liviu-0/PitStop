@page "/auth/forgot-password"
@rendermode InteractiveServer

<PageTitle>Parolă uitată - PitStop</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex"/>
</HeadContent>

<div class="min-h-screen bg-surface flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-[440px] bg-white rounded-xl shadow-md p-8">

        <div class="text-center mb-8">
            <h1 class="text-3xl font-black italic tracking-tighter text-brand-red"
                style="font-family: Manrope, sans-serif;">PitStop</h1>
            <p class="text-text-muted text-sm mt-2">Introdu adresa de email și îți trimitem un link de resetare.</p>
        </div>

        @if (_sent)
        {
            <div class="flex flex-col items-center gap-4 text-center py-4">
                <span class="material-symbols-outlined text-5xl text-green-500">mark_email_read</span>
                <p class="font-bold text-text-main">Verifică-ți emailul</p>
                <p class="text-sm text-text-muted">Dacă adresa introdusă este asociată unui cont, vei primi un link de
                    resetare în câteva minute.</p>
                <a href="/auth/login" class="mt-2 text-brand-red font-bold text-sm hover:underline">
                    Înapoi la autentificare
                </a>
            </div>
        }
        else
        {
            <form method="post" action="/auth/do-forgot-password" class="space-y-5">
                <AntiforgeryToken/>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold uppercase tracking-wider text-text-muted px-1">Email</label>
                    <input name="email" type="email" placeholder="nume@exemplu.ro" autofocus
                           class="w-full px-4 py-3 bg-surface-bright rounded-lg border border-border-light focus:ring-2 focus:ring-brand-red/30 focus:border-brand-red text-sm outline-none transition-all"/>
                </div>

                @if (Sent == "1")
                {
                    <div class="flex flex-col items-center gap-3 text-center py-2">
                        <span class="material-symbols-outlined text-4xl text-green-500">mark_email_read</span>
                        <p class="text-sm text-text-muted">Dacă adresa este asociată unui cont, vei primi un email în
                            câteva minute.</p>
                    </div>
                }

                <button type="submit"
                        class="w-full py-3.5 bg-brand-red hover:bg-brand-red-dark text-white font-bold rounded-lg transition-all active:scale-[0.98]"
                        style="font-family: Manrope, sans-serif;">
                    Trimite link de resetare
                </button>

                <p class="text-center text-sm text-text-muted">
                    <a href="/auth/login" class="text-brand-red font-bold hover:underline">
                        Înapoi la autentificare
                    </a>
                </p>
            </form>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? Sent { get; set; }

    private bool _sent;

    protected override void OnParametersSet()
    {
        _sent = Sent == "1";
    }

}
