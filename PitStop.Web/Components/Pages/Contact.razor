@page "/contact"
@rendermode InteractiveServer
@inject IShopRequestRepository ShopRequestRepo

<PageTitle>Contact - PitStop</PageTitle>

<!-- ─── HERO ─── -->
<section class="bg-hero-dark text-white pt-28 pb-36 px-6 md:px-12 text-center">
    <div class="max-w-3xl mx-auto flex flex-col items-center gap-5">
        <span class="inline-block px-5 py-1.5 rounded-full bg-white/10 border border-white/20 text-white text-xs font-bold tracking-widest uppercase">
            Suntem aici pentru tine
        </span>
        <h1 class="font-black text-4xl md:text-6xl tracking-tight" style="font-family: Manrope, sans-serif;">
            Contactează-ne
        </h1>
        <p class="text-lg text-white/70 max-w-xl leading-relaxed">
            Ai întrebări, sugestii sau vrei să listezi un service? Echipa PitStop îți răspunde în cel mai scurt timp.
        </p>
    </div>
</section>

<!-- ─── FORM + INFO CARDS ─── -->
<section class="bg-surface-bright py-16 px-6 md:px-12">
    <div class="max-w-screen-xl mx-auto -mt-24">
        <div class="grid grid-cols-1 lg:grid-cols-7 gap-8 items-start">

            <!-- Contact Form -->
            <div class="lg:col-span-4 bg-white rounded-2xl border border-border-light shadow-sm p-8 md:p-10">
                <h2 class="font-bold text-2xl text-text-main mb-1" style="font-family: Manrope, sans-serif;">Trimite-ne un mesaj</h2>
                <p class="text-text-muted text-sm mb-8">Completează formularul și te contactăm în maxim 24 de ore.</p>

                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault class="flex flex-col gap-5">
                    <!-- Name + Email row -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-text-main">Nume complet</label>
                            <input @bind="FormName" type="text" placeholder="Ion Popescu"
                                   class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main placeholder-text-muted focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-text-main">Email</label>
                            <input @bind="FormEmail" type="email" placeholder="ion@exemplu.ro"
                                   class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main placeholder-text-muted focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors" />
                        </div>
                    </div>

                    <!-- Subject -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-semibold text-text-main">Subiect</label>
                        <select @bind="FormSubject"
                                class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors bg-white">
                            <option value="" disabled>Selectează un subiect</option>
                            <option value="listing">Vreau să listez un service</option>
                            <option value="support">Suport tehnic</option>
                            <option value="review">Problemă cu o recenzie</option>
                            <option value="partnership">Parteneriat</option>
                            <option value="other">Altele</option>
                        </select>
                    </div>

                    <!-- Message -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-semibold text-text-main">Mesaj</label>
                        <textarea @bind="FormMessage" rows="5" placeholder="Descrie pe scurt cum te putem ajuta..."
                                  class="border border-border-light rounded-lg px-4 py-2.5 text-sm text-text-main placeholder-text-muted focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-colors resize-none"></textarea>
                    </div>

                    @if (SubmitSuccess)
                    {
                        <div class="flex items-center gap-3 bg-green-50 border border-green-200 rounded-lg px-4 py-3 text-sm text-green-700">
                            <span class="material-symbols-outlined text-lg">check_circle</span>
                            Mesajul tău a fost trimis! Te contactăm în curând.
                        </div>
                    }

                    <button type="submit"
                            class="bg-brand-red hover:bg-brand-red-dark text-white font-bold text-sm px-8 py-3 rounded-lg transition-colors shadow-sm self-start">
                        Trimite mesajul
                    </button>

                    <p class="text-xs text-text-muted">
                        Prin trimiterea acestui formular ești de acord cu
                        <a href="#" class="text-brand-red hover:underline">Politica de Confidențialitate</a>.
                    </p>
                </form>
            </div>

            <!-- Info Cards -->
            <div class="lg:col-span-3 flex flex-col gap-4">

                <div class="bg-white rounded-xl border border-border-light p-6 flex items-start gap-4">
                    <div class="w-12 h-12 rounded-xl bg-brand-red-faint flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-xl text-brand-red" style="font-variation-settings: 'FILL' 1;">mail</span>
                    </div>
                    <div>
                        <p class="font-bold text-sm text-text-main mb-0.5">Email</p>
                        <p class="text-text-muted text-sm">contact@pitstop.ro</p>
                        <p class="text-text-muted text-sm">suport@pitstop.ro</p>
                    </div>
                </div>

                <div class="bg-white rounded-xl border border-border-light p-6 flex items-start gap-4">
                    <div class="w-12 h-12 rounded-xl bg-secondary-light flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-xl text-secondary" style="font-variation-settings: 'FILL' 1;">phone</span>
                    </div>
                    <div>
                        <p class="font-bold text-sm text-text-main mb-0.5">Telefon</p>
                        <p class="text-text-muted text-sm">+40 721 000 000</p>
                        <p class="text-text-muted text-xs text-text-muted/70 mt-0.5">Luni–Vineri, 09:00–18:00</p>
                    </div>
                </div>

                <div class="bg-white rounded-xl border border-border-light p-6 flex items-start gap-4">
                    <div class="w-12 h-12 rounded-xl bg-surface-low flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-xl text-brand-blue" style="font-variation-settings: 'FILL' 1;">schedule</span>
                    </div>
                    <div>
                        <p class="font-bold text-sm text-text-main mb-0.5">Program</p>
                        <p class="text-text-muted text-sm">Luni–Vineri: 09:00–18:00</p>
                        <p class="text-text-muted text-sm">Sâmbătă: 10:00–14:00</p>
                    </div>
                </div>

                <div class="bg-white rounded-xl border border-border-light p-6 flex items-start gap-4">
                    <div class="w-12 h-12 rounded-xl bg-surface-container flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-xl text-text-main" style="font-variation-settings: 'FILL' 1;">location_on</span>
                    </div>
                    <div>
                        <p class="font-bold text-sm text-text-main mb-0.5">Locație</p>
                        <p class="text-text-muted text-sm">București, România</p>
                        <p class="text-text-muted text-xs mt-0.5">Operăm la nivel național</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<!-- ─── FAQ ─── -->
<section class="bg-surface-container py-24 px-6 md:px-12">
    <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
            <h2 class="font-bold text-3xl md:text-4xl text-text-main mb-3" style="font-family: Manrope, sans-serif;">Întrebări frecvente</h2>
            <p class="text-text-muted">Răspunsuri la cele mai comune întrebări despre PitStop.</p>
        </div>

        <div class="flex flex-col gap-3">
            @foreach (var (faq, index) in Faqs.Select((f, i) => (f, i)))
            {
                <div class="bg-white rounded-xl border border-border-light overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left gap-4"
                            @onclick="() => ToggleFaq(index)">
                        <span class="font-semibold text-text-main text-sm md:text-base">@faq.Question</span>
                        <span class="material-symbols-outlined text-text-muted shrink-0 transition-transform duration-200 @(OpenFaq == index ? "rotate-180" : "")">
                            expand_more
                        </span>
                    </button>
                    @if (OpenFaq == index)
                    {
                        <div class="px-6 pb-5 text-text-muted text-sm leading-relaxed border-t border-border-light pt-4">
                            @faq.Answer
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</section>

<CTASection Variant="CTASection.CTAVariant.DarkHorizontal"
            Title="Ai un service auto sau moto?"
            Subtitle="Listează-ți serviciul pe PitStop și conectează-te cu mii de clienți din România."
            ButtonText="Listează-ți serviciul" />

@code {
    private string FormName { get; set; } = string.Empty;
    private string FormEmail { get; set; } = string.Empty;
    private string FormSubject { get; set; } = string.Empty;
    private string FormMessage { get; set; } = string.Empty;
    private bool SubmitSuccess { get; set; }

    private int? OpenFaq { get; set; }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(FormName) || string.IsNullOrWhiteSpace(FormEmail))
            return;

        if (FormSubject == "listing")
        {
            await ShopRequestRepo.CreateAsync(new ShopRequest
            {
                ContactPerson = FormName,
                Email = FormEmail,
                Description = FormMessage,
                ShopName = "Cerere prin formular contact",
                Category = ShopCategory.Altele,
                City = string.Empty,
                County = string.Empty,
                Phone = string.Empty,
            });
        }

        SubmitSuccess = true;
        FormName = string.Empty;
        FormEmail = string.Empty;
        FormSubject = string.Empty;
        FormMessage = string.Empty;
    }

    private void ToggleFaq(int index)
    {
        OpenFaq = OpenFaq == index ? null : index;
    }

    private record FaqItem(string Question, string Answer);

    private static readonly List<FaqItem> Faqs =
    [
        new("Cum pot lista un service pe PitStop?",
            "Poți lista un service completând formularul de înregistrare din secțiunea 'Listează-ți serviciul'. Echipa noastră va verifica informațiile și va aproba listarea în cel mult 48 de ore."),
        new("Este gratuită listarea pe PitStop?",
            "Da, listarea de bază este complet gratuită. Oferim și planuri premium cu funcționalități suplimentare, cum ar fi poziționare prioritară și statistici detaliate."),
        new("Cum pot lăsa o recenzie pentru un service?",
            "Trebuie să ai un cont activ pe PitStop. După autentificare, navighează la pagina serviciului dorit și folosește butonul 'Lasă o recenzie'. Recenziile sunt moderate înainte de publicare."),
        new("Ce fac dacă informațiile unui service sunt incorecte?",
            "Folosește butonul 'Raportează o problemă' din pagina serviciului sau contactează-ne direct la suport@pitstop.ro. Vom verifica și actualiza informațiile în cel mai scurt timp."),
    ];
}
