{
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Skill(claude-md-management:revise-claude-md)",
      "Bash(dotnet build *)",
      "Bash(xargs grep *)",
      "Bash(xargs ls *)",
      "Bash(dotnet package *)",
      "Bash(dotnet restore *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(dotnet ef migrations *)",
      "Bash(~/.dotnet/tools/dotnet-ef migrations *)",
      "Bash(MSBUILDTERMINALLOGGER=off dotnet build PitStop.sln -p:AllowMissingPrunePackageData=true)",
      "Bash(MSBUILDTERMINALLOGGER=off ~/.dotnet/tools/dotnet-ef migrations *)",
      "Bash(~/.dotnet/tools/dotnet-ef database *)",
      "Bash(git reset *)",
      "Bash(git commit *)"
    ]
  }
}
